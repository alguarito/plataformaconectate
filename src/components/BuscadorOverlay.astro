---
/**
 * Buscador global de ConectaTE.
 *
 * - Indexa al BUILD las 180 guías + 18 proyectos (198 items).
 * - Búsqueda en vivo (≥ 2 chars), insensible a tildes y a mayúsculas.
 * - Resultados resaltados, agrupados por grado.
 * - Marca con ✓ los items ya completados (engancha con localStorage).
 * - Navegación con teclado: ↑ ↓ para moverse, Enter para abrir, Esc para cerrar.
 * - Atajos para abrir: ⌘ K, Ctrl K, /.
 */
import { grados } from '../data/grados';
import { recursos } from '../data/recursos';

const base = import.meta.env.BASE_URL;

function normalizar(s: string): string {
  return s
    .toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .trim();
}

interface ItemIndice {
  tipo: 'guia' | 'proyecto';
  grado: number;
  periodo: number;
  sesion: number; // 0 para proyectos, así seguimos teniendo número
  titulo: string;
  contexto: string; // ej. "P1 · Sesión 1"
  href: string;
  k: string; // texto normalizado
  bgClass: string; // color del período (badge)
}

// Mapa rápido grado→periodo→bgClass para los badges
const colorPorPeriodo: Record<string, string> = {};
for (const g of grados) {
  for (const p of g.periodos) {
    colorPorPeriodo[`${g.numero}-${p.numero}`] = p.bgClass;
  }
}

const indice: ItemIndice[] = [
  ...recursos.map((r) => ({
    tipo: 'guia' as const,
    grado: r.grado,
    periodo: r.periodo,
    sesion: r.sesion,
    titulo: r.titulo,
    contexto: `P${r.periodo} · Sesión ${r.sesion}`,
    href: `${base}/grado-${r.grado}/periodo-${r.periodo}/guia-${r.sesion}`,
    k: normalizar(r.titulo),
    bgClass: colorPorPeriodo[`${r.grado}-${r.periodo}`] ?? 'bg-bento-blue',
  })),
  ...grados.flatMap((g) =>
    g.periodos.map((p) => ({
      tipo: 'proyecto' as const,
      grado: g.numero,
      periodo: p.numero,
      sesion: 0,
      titulo: `Proyecto integrador · ${p.titulo}`,
      contexto: `Período ${p.numero}`,
      href: `${base}/grado-${g.numero}/periodo-${p.numero}/proyecto`,
      k: normalizar(`proyecto integrador ${p.titulo} ${p.descripcion}`),
      bgClass: p.bgClass,
    })),
  ),
];

const totalItems = indice.length;
---

<dialog
  id="buscador-overlay"
  class="bg-transparent p-0 m-0 max-w-none w-full max-h-none h-full backdrop:bg-black/70 backdrop:backdrop-blur-sm"
>
  <div class="fixed inset-0 flex items-start md:items-center justify-center p-0 md:p-6 md:pt-20">
    <div
      class="w-full md:max-w-2xl h-full md:h-auto md:max-h-[80vh] flex flex-col rounded-none md:rounded-bento-lg shadow-2xl overflow-hidden"
      style="background: var(--bg);"
    >
      {/* Caja de búsqueda */}
      <div class="flex items-center gap-3 px-5 md:px-6 py-4 border-b" style="border-color: var(--border);">
        <svg class="w-5 h-5 shrink-0" style="color: var(--fg-muted);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          id="buscador-input"
          type="search"
          placeholder={`Busca entre ${totalItems} guías y proyectos…`}
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          class="flex-1 bg-transparent border-none outline-none text-base md:text-lg font-semibold placeholder:font-normal"
          style="color: var(--fg);"
        />
        <kbd class="hidden md:inline-flex text-xs font-bold px-2 py-1 rounded-md border" style="border-color: var(--border); color: var(--fg-muted);">
          Esc
        </kbd>
        <button
          type="button"
          data-cerrar-buscador
          aria-label="Cerrar buscador"
          class="w-8 h-8 rounded-full flex items-center justify-center hover:opacity-70 transition-opacity md:hidden"
          style="background: var(--border);"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>

      {/* Resultados */}
      <div
        id="buscador-resultados"
        class="flex-1 overflow-y-auto p-3 md:p-4"
        role="listbox"
      >
        <div id="buscador-vacio" class="text-center py-12 px-6">
          <div class="text-5xl mb-3">🔎</div>
          <div class="font-bold text-lg mb-1">Empieza a escribir</div>
          <div class="text-sm" style="color: var(--fg-muted);">
            Busca por tema (ej. "excel", "phishing", "scratch") o por grado y sesión.
          </div>
        </div>
      </div>

      {/* Footer con tips de teclado (desktop) */}
      <div class="hidden md:flex items-center gap-4 px-5 py-3 border-t text-xs font-semibold" style="border-color: var(--border); color: var(--fg-muted);">
        <span class="flex items-center gap-1.5">
          <kbd class="px-1.5 py-0.5 rounded border" style="border-color: var(--border);">↑</kbd>
          <kbd class="px-1.5 py-0.5 rounded border" style="border-color: var(--border);">↓</kbd>
          navegar
        </span>
        <span class="flex items-center gap-1.5">
          <kbd class="px-1.5 py-0.5 rounded border" style="border-color: var(--border);">Enter</kbd>
          abrir
        </span>
        <span class="flex items-center gap-1.5">
          <kbd class="px-1.5 py-0.5 rounded border" style="border-color: var(--border);">/</kbd>
          o
          <kbd class="px-1.5 py-0.5 rounded border" style="border-color: var(--border);">⌘ K</kbd>
          abrir
        </span>
      </div>
    </div>
  </div>
</dialog>

<script define:vars={{ indice }}>
  const dialog = document.getElementById('buscador-overlay');
  const input = document.getElementById('buscador-input');
  const out = document.getElementById('buscador-resultados');
  const vacio = document.getElementById('buscador-vacio');

  if (!dialog || !input || !out) {
    // SSR / desconexión — no continuamos
  } else {
    /** Helpers ---------------------------------------------------------- */

    function normalizar(s) {
      return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').trim();
    }

    function escapeHtml(s) {
      return s
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    /** Devuelve el HTML del título con los matches resaltados. */
    function resaltar(titulo, queryNorm) {
      if (!queryNorm) return escapeHtml(titulo);
      const tNorm = normalizar(titulo);
      const idx = tNorm.indexOf(queryNorm);
      if (idx < 0) return escapeHtml(titulo);
      // mismo índice porque normalizar no cambia la longitud (sí: NFD elimina diacríticos
      // pero como contamos sobre la normalizada y el original puede tener tildes, podríamos
      // tener un offset. Para robustez, hacemos un mapeo char-a-char.)
      let visible = '';
      let normCount = 0;
      let highlighted = false;
      for (let i = 0; i < titulo.length; i++) {
        const ch = titulo[i];
        const chNorm = normalizar(ch);
        if (!highlighted && normCount === idx) {
          visible += '<mark>';
        }
        visible += escapeHtml(ch);
        if (chNorm.length > 0) {
          normCount += chNorm.length;
          if (!highlighted && normCount >= idx + queryNorm.length) {
            visible += '</mark>';
            highlighted = true;
          }
        }
      }
      if (!highlighted) visible += '</mark>';
      return visible;
    }

    /** Lee el estado de progreso de localStorage para los checks ✓. */
    function leerCompletadas() {
      try {
        const raw = localStorage.getItem('conectate.progreso.v1');
        if (!raw) return { guias: {}, proyectos: {} };
        const p = JSON.parse(raw);
        return { guias: p?.guias ?? {}, proyectos: p?.proyectos ?? {} };
      } catch {
        return { guias: {}, proyectos: {} };
      }
    }

    function estaCompletado(item) {
      const c = leerCompletadas();
      if (item.tipo === 'guia') {
        return `g${item.grado}-p${item.periodo}-s${item.sesion}` in c.guias;
      }
      return `g${item.grado}-p${item.periodo}` in c.proyectos;
    }

    /** Búsqueda + render ----------------------------------------------- */

    let resultadosActuales = [];
    let cursor = -1;

    function render(q) {
      const qn = normalizar(q);
      if (qn.length < 2) {
        resultadosActuales = [];
        cursor = -1;
        out.innerHTML = '';
        out.appendChild(vacio);
        return;
      }
      const matches = indice.filter((i) => i.k.includes(qn)).slice(0, 30);
      resultadosActuales = matches;
      cursor = matches.length > 0 ? 0 : -1;

      if (matches.length === 0) {
        out.innerHTML = `
          <div class="text-center py-12 px-6">
            <div class="text-5xl mb-3">🤔</div>
            <div class="font-bold text-lg mb-1">Sin resultados para "${escapeHtml(q)}"</div>
            <div class="text-sm" style="color: var(--fg-muted);">
              Prueba con otra palabra clave (sin acentos, en singular).
            </div>
          </div>`;
        return;
      }

      // Agrupar por grado
      const porGrado = new Map();
      for (const m of matches) {
        if (!porGrado.has(m.grado)) porGrado.set(m.grado, []);
        porGrado.get(m.grado).push(m);
      }

      const partes = [];
      partes.push(
        `<div class="text-xs font-bold uppercase tracking-widest mb-3 px-2" style="color: var(--fg-muted);">
          ${matches.length} ${matches.length === 1 ? 'resultado' : 'resultados'}
        </div>`,
      );

      let idxGlobal = 0;
      for (const [grado, items] of [...porGrado.entries()].sort((a, b) => a[0] - b[0])) {
        partes.push(
          `<div class="text-xs font-black uppercase tracking-widest mt-3 mb-2 px-2 opacity-60">
            Grado ${grado}°
          </div>`,
        );
        for (const it of items) {
          const completado = estaCompletado(it);
          const icono = it.tipo === 'proyecto' ? '🎯' : '📄';
          partes.push(`
            <a
              href="${escapeHtml(it.href)}"
              data-resultado-idx="${idxGlobal}"
              class="buscador-resultado flex items-start gap-3 p-3 rounded-bento-sm hover:opacity-90 transition-opacity"
            >
              <span class="text-2xl shrink-0">${icono}</span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap mb-1">
                  <span class="px-2 py-0.5 rounded-full text-[10px] font-black uppercase tracking-widest ${escapeHtml(it.bgClass)}">
                    ${escapeHtml(it.contexto)}
                  </span>
                  ${completado ? '<span class="text-xs font-bold text-bento-lime">✓ Completada</span>' : ''}
                </div>
                <div class="font-bold leading-snug">${resaltar(it.titulo, qn)}</div>
              </div>
              <svg class="w-5 h-5 shrink-0 mt-1 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"></path>
              </svg>
            </a>`);
          idxGlobal++;
        }
      }

      out.innerHTML = partes.join('');
      pintarCursor();
    }

    function pintarCursor() {
      out.querySelectorAll('.buscador-resultado').forEach((el, i) => {
        if (i === cursor) {
          el.classList.add('bg-bento-blue', 'text-white');
          el.scrollIntoView({ block: 'nearest' });
        } else {
          el.classList.remove('bg-bento-blue', 'text-white');
        }
      });
    }

    /** Eventos --------------------------------------------------------- */

    input.addEventListener('input', (e) => {
      render((e.target).value);
    });

    input.addEventListener('keydown', (e) => {
      if (resultadosActuales.length === 0) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        cursor = (cursor + 1) % resultadosActuales.length;
        pintarCursor();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        cursor = (cursor - 1 + resultadosActuales.length) % resultadosActuales.length;
        pintarCursor();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        const item = resultadosActuales[cursor];
        if (item) window.location.href = item.href;
      }
    });

    document.querySelectorAll('[data-cerrar-buscador]').forEach((b) => {
      b.addEventListener('click', () => dialog.close());
    });

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    /** Apertura -------------------------------------------------------- */

    function abrir() {
      if (typeof dialog.showModal === 'function') dialog.showModal();
      requestAnimationFrame(() => input.focus());
    }

    document.querySelectorAll('[data-abrir-buscador]').forEach((b) => {
      b.addEventListener('click', abrir);
    });

    // Atajos globales: ⌘K / Ctrl+K / "/"
    document.addEventListener('keydown', (e) => {
      const enInput =
        e.target instanceof HTMLInputElement ||
        e.target instanceof HTMLTextAreaElement ||
        (e.target instanceof HTMLElement && e.target.isContentEditable);

      // ⌘ K / Ctrl K
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        abrir();
        return;
      }
      // "/" cuando NO se está escribiendo en otro lado
      if (e.key === '/' && !enInput && !dialog.open) {
        e.preventDefault();
        abrir();
      }
    });
  }
</script>

<style>
  /* Resaltado de coincidencias */
  #buscador-resultados mark {
    background: var(--bento-yellow, #FFD60A);
    color: black;
    padding: 0 2px;
    border-radius: 3px;
    font-weight: 800;
  }

  /* Animación de entrada del overlay */
  #buscador-overlay[open] > div > div {
    animation: buscador-pop 0.2s ease-out;
  }
  @keyframes buscador-pop {
    from {
      opacity: 0;
      transform: translateY(-12px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

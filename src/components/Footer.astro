---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();

// WhatsApp del docente (formato internacional sin "+", para wa.me)
const whatsappNumero = '573206324740';
const whatsappVisible = '+57 320 632 4740';
const whatsappMensaje =
  'Hola Dr. Cárdenas, le escribo desde la plataforma ConectaTE.';
const whatsappHref = `https://wa.me/${whatsappNumero}?text=${encodeURIComponent(whatsappMensaje)}`;
---

<footer class="border-t mt-24" style="border-color: var(--border);">
  <div class="bento-container py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href={base || '/'} class="inline-flex items-center gap-3 mb-4 group hover:opacity-80 transition-opacity">
          <img
            src={`${base}/LOGO.png`}
            alt="ConectaTE"
            class="w-12 h-12 rounded-full object-cover transition-transform duration-300 group-hover:rotate-12"
            loading="lazy"
          />
          <span class="font-black text-xl tracking-tighter leading-none">
            Conecta<span class="text-bento-blue">TE</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed max-w-xs" style="color: var(--fg-muted);">
          Conectando Tecnología con Educación. 180 guías y 18 proyectos para
          grados 6° a 11°.
        </p>
      </div>

      <div>
        <h4 class="font-black text-sm uppercase tracking-widest mb-3">
          Institución
        </h4>
        <p class="text-sm leading-relaxed mb-3" style="color: var(--fg-muted);">
          I.E. Sor María Juliana<br />
          Cartago, Valle del Cauca<br />
          Colombia
        </p>
        <a
          href={`${base}/plan-de-area`}
          class="inline-block text-sm font-bold underline hover:opacity-70 transition-opacity"
        >
          Plan de Área 2025 →
        </a>
      </div>

      <div>
        <h4 class="font-black text-sm uppercase tracking-widest mb-3">
          Docente
        </h4>
        <p class="text-sm leading-relaxed mb-3" style="color: var(--fg-muted);">
          <strong style="color: var(--fg);">Dr. Álvaro Cárdenas Orozco</strong><br />
          Tecnología e Informática · Grados 6° a 11°
        </p>
        <a
          href={`${base}/acerca`}
          class="inline-block text-sm font-bold underline mb-4 hover:opacity-70 transition-opacity"
        >
          Ver trayectoria completa →
        </a>

        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold bg-[#25D366] text-white hover:scale-105 active:scale-95 transition-transform shadow-sm"
          aria-label={`Escribir al docente por WhatsApp ${whatsappVisible}`}
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.91 9.91 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.02ZM12.04 20.15h-.01a8.23 8.23 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.39c0-4.54 3.7-8.24 8.25-8.24a8.18 8.18 0 0 1 5.83 2.42 8.2 8.2 0 0 1 2.42 5.83c0 4.54-3.7 8.24-8.25 8.24Zm4.52-6.16c-.25-.12-1.46-.72-1.69-.8-.23-.08-.39-.12-.56.12-.16.25-.64.8-.79.96-.15.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.47-1.38-1.72-.15-.25-.02-.38.11-.5.11-.11.25-.29.37-.43.12-.15.16-.25.25-.42.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.16 0-.43.06-.66.31s-.86.85-.86 2.06c0 1.21.88 2.39 1 2.55.12.17 1.74 2.66 4.21 3.74.59.26 1.05.41 1.4.52.59.19 1.13.16 1.55.1.47-.07 1.46-.6 1.66-1.17.21-.58.21-1.07.15-1.17-.06-.1-.22-.16-.46-.28Z"/>
          </svg>
          Escríbeme por WhatsApp
        </a>

        <div class="text-xs mt-2" style="color: var(--fg-muted);">
          {whatsappVisible}
        </div>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t flex flex-col sm:flex-row justify-between items-center gap-4 text-xs" style="border-color: var(--border); color: var(--fg-muted);">
      <p>© {year} ConectaTE — Todos los derechos reservados</p>
      <p>Hecho con ❤ para los estudiantes de Sor María Juliana</p>
    </div>
  </div>
</footer>

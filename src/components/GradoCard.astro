---
interface Props {
  numero: number;
  titulo: string;
  descripcion: string;
  bgClass: string;
  icono: string;
  href: string;
  size?: 'normal' | 'large';
}

const { numero, titulo, descripcion, bgClass, icono, href, size = 'normal' } = Astro.props;

const sizeClasses = size === 'large'
  ? 'md:col-span-8 md:row-span-2 min-h-[420px]'
  : 'md:col-span-4 min-h-[280px]';
---

<a
  href={href}
  class={`bento-card-color group ${bgClass} ${sizeClasses} flex flex-col justify-between hover:scale-[1.01] active:scale-[0.99] transition-transform duration-300`}
>
  <div class="flex items-start justify-between">
    <div class="text-7xl md:text-8xl font-black tracking-tighter leading-none">
      {numero}°
    </div>
    <div class="text-5xl md:text-6xl">
      {icono}
    </div>
  </div>

  <div class="mt-8">
    <h3 class={`${size === 'large' ? 'text-3xl md:text-5xl' : 'text-2xl md:text-3xl'} font-black tracking-tight mb-3 leading-tight`}>
      {titulo}
    </h3>
    <p class={`${size === 'large' ? 'text-base md:text-lg' : 'text-sm md:text-base'} opacity-80 leading-relaxed mb-6 max-w-md`}>
      {descripcion}
    </p>

    <div class="flex items-center gap-2 font-bold group-hover:gap-3 transition-all">
      Ver contenido
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </div>
  </div>
</a>

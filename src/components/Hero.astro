---
const base = import.meta.env.BASE_URL;
---

<section class="pt-12 pb-16 md:pt-20 md:pb-24">
  <div class="bento-container">
    <!-- Etiqueta institucional -->
    <div class="flex items-center gap-2 mb-8 animate-fade-in">
      <span class="w-2 h-2 rounded-full bg-bento-lime"></span>
      <span class="text-xs font-semibold uppercase tracking-widest" style="color: var(--fg-muted);">
        I.E. Sor María Juliana · Cartago
      </span>
    </div>

    <!-- Título mega -->
    <h1 class="heading-mega text-balance mb-6 animate-slide-up">
      Conecta<span class="text-bento-blue">TE</span>.
    </h1>

    <p
      class="text-xl md:text-3xl font-medium max-w-3xl text-balance leading-tight mb-10 animate-slide-up"
      style="color: var(--fg-muted); animation-delay: 0.1s;"
    >
      Conectando <span class="font-bold" style="color: var(--fg);">tecnología</span> con <span class="font-bold" style="color: var(--fg);">educación</span>. 150 guías y 15 proyectos para grados 6° a 10°.
    </p>

    <div
      class="flex flex-wrap gap-3 animate-slide-up"
      style="animation-delay: 0.2s;"
    >
      <a href="#grados" class="btn-bento">
        Explorar grados
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"></path>
        </svg>
      </a>
      <a href={`${base}/registro`} class="btn-bento-outline">
        Crear cuenta gratis
      </a>
    </div>
  </div>
</section>

---
import ThemeToggle from './ThemeToggle.astro';
const base = import.meta.env.BASE_URL;

const grados = [6, 7, 8, 9, 10, 11];
---

<header class="sticky top-0 z-50 w-full">
  <div
    class="border-b backdrop-blur-xl"
    style="background-color: color-mix(in srgb, var(--bg) 80%, transparent); border-color: var(--border);"
  >
    <div class="bento-container flex items-center justify-between h-16">
      <a href={base || '/'} class="group inline-flex items-baseline transition-opacity hover:opacity-80">
        <span class="font-black text-xl tracking-tighter leading-none">
          Conecta<span class="text-bento-blue">TE</span>
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-1">
        {
          grados.map((g) => (
            <a
              href={`${base}/grado-${g}`}
              class="px-3 py-1.5 rounded-full text-sm font-semibold hover:bg-[var(--border)] transition-colors"
            >
              {g}°
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <ThemeToggle />
        <a
          href={`${base}/registro`}
          class="hidden sm:inline-flex btn-bento text-sm px-5 py-2"
        >
          Ingresar
        </a>
      </div>
    </div>
  </div>
</header>

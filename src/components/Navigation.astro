---
import ThemeToggle from './ThemeToggle.astro';
import PerfilChip from './PerfilChip.astro';
const base = import.meta.env.BASE_URL;

const grados = [6, 7, 8, 9, 10, 11];
---

<header class="sticky top-0 z-50 w-full">
  <div
    class="border-b backdrop-blur-xl"
    style="background-color: color-mix(in srgb, var(--bg) 80%, transparent); border-color: var(--border);"
  >
    <div class="bento-container flex items-center justify-between h-16">
      <a href={base || '/'} class="group inline-flex items-baseline transition-opacity hover:opacity-80">
        <span class="font-black text-xl tracking-tighter leading-none">
          Conecta<span class="text-bento-blue">TE</span>
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-1">
        {
          grados.map((g) => (
            <a
              href={`${base}/grado-${g}`}
              class="px-3 py-1.5 rounded-full text-sm font-semibold hover:bg-[var(--border)] transition-colors"
            >
              {g}°
            </a>
          ))
        }
        <a
          href={`${base}/acerca`}
          class="px-3 py-1.5 rounded-full text-sm font-semibold hover:bg-[var(--border)] transition-colors ml-2"
          title="Acerca del docente"
        >
          Acerca de
        </a>
      </nav>

      <div class="flex items-center gap-2">
        <PerfilChip />
        <button
          type="button"
          data-abrir-buscador
          aria-label="Buscar"
          class="w-9 h-9 rounded-full flex items-center justify-center hover:bg-[var(--border)] transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </button>
        <ThemeToggle />
        <a
          href={`${base}/registro`}
          class="hidden sm:inline-flex btn-bento text-sm px-5 py-2"
        >
          Ingresar
        </a>
      </div>
    </div>
  </div>
</header>

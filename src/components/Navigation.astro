---
import ThemeToggle from './ThemeToggle.astro';
const base = import.meta.env.BASE_URL;

const grados = [6, 7, 8, 9, 10, 11];
---

<header class="sticky top-0 z-50 w-full">
  <div
    class="border-b backdrop-blur-xl"
    style="background-color: color-mix(in srgb, var(--bg) 80%, transparent); border-color: var(--border);"
  >
    <div class="bento-container flex items-center justify-between h-16">
      <a href={base || '/'} class="flex items-center gap-3 group">
        <img
          src={`${base}/LOGO.png`}
          alt="ConectaTE"
          class="w-9 h-9 rounded-full object-cover transition-transform duration-300 group-hover:rotate-12"
        />
        <span class="font-black text-lg tracking-tighter">ConectaTE</span>
      </a>

      <nav class="hidden md:flex items-center gap-1">
        {
          grados.map((g) => (
            <a
              href={`${base}/grado-${g}`}
              class="px-3 py-1.5 rounded-full text-sm font-semibold hover:bg-[var(--border)] transition-colors"
            >
              {g}°
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <ThemeToggle />
        <a
          href={`${base}/registro`}
          class="hidden sm:inline-flex btn-bento text-sm px-5 py-2"
        >
          Ingresar
        </a>
      </div>
    </div>
  </div>
</header>

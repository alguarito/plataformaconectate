---
/**
 * Modal de onboarding: pregunta al estudiante en qué grado está.
 *
 * - Se muestra automáticamente la primera vez (cuando no hay grado en localStorage).
 * - Reabre desde cualquier botón con [data-abrir-onboarding].
 * - Tres caminos: elegir grado / cambiar grado / continuar como invitado.
 */
import { grados } from '../data/grados';
---

<dialog
  id="onboarding-grado"
  class="bg-transparent p-0 m-0 max-w-none w-full max-h-none h-full backdrop:bg-black/70 backdrop:backdrop-blur-sm"
>
  <div class="fixed inset-0 flex items-end md:items-center justify-center p-0 md:p-6">
    <div
      class="w-full md:max-w-2xl max-h-[92vh] overflow-y-auto rounded-t-3xl md:rounded-bento-lg shadow-2xl"
      style="background: var(--bg);"
    >
      <div class="p-6 md:p-10">
        <div class="w-12 h-1.5 rounded-full mx-auto mb-6 md:hidden" style="background: var(--border);"></div>

        <div class="flex items-start justify-between gap-4 mb-2">
          <div class="flex-1">
            <span class="chip-bento mb-3">Bienvenida · Bienvenido</span>
            <h2 class="text-3xl md:text-4xl font-black tracking-tight leading-tight">
              ¿En qué grado estás?
            </h2>
            <p class="mt-3 text-sm md:text-base leading-relaxed" style="color: var(--fg-muted);">
              Tu progreso se guarda en este navegador y se separa entre <strong>tu grado</strong> y la <strong>exploración</strong> de otros grados.
            </p>
          </div>
          <button
            type="button"
            data-cerrar-onboarding
            aria-label="Cerrar"
            class="w-10 h-10 rounded-full flex items-center justify-center hover:opacity-70 transition-opacity shrink-0"
            style="background: var(--border);"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-8">
          {
            grados.map((g) => (
              <button
                type="button"
                data-elegir-grado={g.numero}
                class={`bento-card-color ${g.bgClass} text-left p-5 active:scale-95 transition-transform group`}
              >
                <div class="flex items-start justify-between mb-3">
                  <div class="text-4xl md:text-5xl font-black tracking-tighter leading-none">
                    {g.numero}°
                  </div>
                  <div class="text-3xl">{g.icono}</div>
                </div>
                <div class="text-xs md:text-sm font-bold opacity-90 line-clamp-2 leading-tight">
                  {g.titulo}
                </div>
              </button>
            ))
          }
        </div>

        <button
          type="button"
          data-elegir-grado="invitado"
          class="w-full mt-4 py-4 rounded-bento-sm font-bold text-sm border-2 hover:opacity-70 transition-opacity"
          style="border-color: var(--border); color: var(--fg);"
        >
          Continuar como invitado (sin progreso de grado)
        </button>

        <p class="text-xs mt-6 leading-relaxed" style="color: var(--fg-muted);">
          🔒 Privacidad: nada se envía a un servidor. Si limpias el caché del navegador,
          el progreso se borra. Puedes cambiar tu grado en cualquier momento desde el chip
          de tu nivel arriba.
        </p>
      </div>
    </div>
  </div>
</dialog>

<script>
  import { leerEstado, setGradoActual } from '../scripts/progreso';

  const dialog = document.getElementById('onboarding-grado') as HTMLDialogElement | null;
  if (dialog) {
    // Abrir automático en primera visita
    const estado = leerEstado();
    if (estado.gradoActual === null && !sessionStorage.getItem('onboarding-omitido')) {
      // Pequeño delay para que la página termine de pintar
      setTimeout(() => dialog.showModal(), 600);
    }

    // Cerrar (X)
    document.querySelectorAll('[data-cerrar-onboarding]').forEach((btn) => {
      btn.addEventListener('click', () => {
        sessionStorage.setItem('onboarding-omitido', '1');
        dialog.close();
      });
    });

    // Cerrar al tocar fuera
    dialog.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === dialog) {
        sessionStorage.setItem('onboarding-omitido', '1');
        dialog.close();
      }
    });

    // Elegir grado
    document.querySelectorAll<HTMLButtonElement>('[data-elegir-grado]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const v = btn.dataset.elegirGrado;
        if (v === 'invitado') {
          sessionStorage.setItem('onboarding-omitido', '1');
        } else if (v) {
          const g = parseInt(v, 10);
          if (!Number.isNaN(g)) setGradoActual(g);
        }
        dialog.close();
      });
    });

    // Reabrir desde otros componentes
    document.querySelectorAll('[data-abrir-onboarding]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.showModal());
    });
  }
</script>

<style>
  #onboarding-grado[open] > div > div {
    animation: onb-pop 0.3s ease-out;
  }
  @keyframes onb-pop {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

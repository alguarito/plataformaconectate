---
/**
 * Chip compacto del estado del usuario en el header.
 *
 * Comportamiento por rol:
 *  - Visitante con grado escogido: muestra nivel + grado, link a re-elegir grado
 *  - Estudiante: emoji 🎓 + grado/grupo + link al /dashboard
 *  - Docente: emoji 👨‍🏫 + "Docente", link a abrir login para cerrar sesión
 */
const base = import.meta.env.BASE_URL;
---

<a
  id="perfil-chip"
  href={`${base}/dashboard`}
  class="hidden items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold hover:opacity-80 transition-opacity"
  style="background: var(--border);"
  aria-label="Tu perfil"
>
  <span data-perfil-emoji>🌱</span>
  <span data-perfil-texto>—</span>
</a>

<script>
  import { calcStats, onCambio } from '../scripts/progreso';
  import { leerPerfil, onCambioPerfil } from '../scripts/perfilUsuario';

  const chip = document.getElementById('perfil-chip') as HTMLAnchorElement | null;
  if (chip) {
    const base = (window as any).__base ?? '';
    function render() {
      const p = leerPerfil();
      const s = calcStats();
      const emoji = chip!.querySelector<HTMLElement>('[data-perfil-emoji]');
      const texto = chip!.querySelector<HTMLElement>('[data-perfil-texto]');

      if (p.rol === 'docente') {
        chip!.classList.remove('hidden');
        chip!.classList.add('inline-flex');
        if (emoji) emoji.textContent = '👨‍🏫';
        if (texto) texto.textContent = 'Docente';
        chip!.setAttribute('data-abrir-login', '');
        chip!.removeAttribute('href');
        return;
      }

      if (p.rol === 'estudiante' && p.grado) {
        chip!.classList.remove('hidden');
        chip!.classList.add('inline-flex');
        if (emoji) emoji.textContent = '🎓';
        if (texto) texto.textContent = `${p.grado}° ${p.grupo ?? ''} · ${s.porcentajeGrado}%`;
        chip!.removeAttribute('data-abrir-login');
        // Link al dashboard
        const links = document.querySelectorAll<HTMLLinkElement>('link[rel="canonical"]');
        const canonical = links[0]?.href ?? '';
        const baseDir = canonical ? new URL(canonical).pathname.split('/').slice(0, 2).join('/') : '';
        chip!.setAttribute('href', `${baseDir}/dashboard`);
        return;
      }

      // Visitante con grado pre-seleccionado (compatibilidad con sistema anterior)
      if (s.gradoActual != null) {
        chip!.classList.remove('hidden');
        chip!.classList.add('inline-flex');
        if (emoji) emoji.textContent = s.nivel.emoji;
        if (texto) texto.textContent = `${s.gradoActual}° · ${s.porcentajeGrado}%`;
        chip!.setAttribute('data-abrir-login', '');
        chip!.removeAttribute('href');
        return;
      }

      // Sin grado, sin rol — esconder
      chip!.classList.add('hidden');
      chip!.classList.remove('inline-flex');
    }
    render();
    onCambio(render);
    onCambioPerfil(render);
  }
</script>

---
interface Props {
  numero: number;
  titulo: string;
  descripcion?: string;
  bgClass: string;
  totalGuias: number;
  href: string;
}

const { numero, titulo, descripcion, bgClass, totalGuias, href } = Astro.props;
---

<a
  href={href}
  class={`bento-card-color group ${bgClass} flex flex-col justify-between min-h-[280px] hover:scale-[1.02] active:scale-[0.99] transition-transform duration-300`}
>
  <div class="flex items-start justify-between">
    <span class="text-xs font-bold uppercase tracking-widest opacity-80">
      Período
    </span>
    <span class="text-7xl font-black tracking-tighter leading-none">
      {numero}
    </span>
  </div>

  <div>
    <h3 class="text-2xl md:text-3xl font-black tracking-tight mb-2 leading-tight">
      {titulo}
    </h3>
    {descripcion && (
      <p class="text-sm opacity-80 leading-relaxed mb-4">
        {descripcion}
      </p>
    )}
    <div class="flex items-center justify-between mt-4">
      <span class="text-sm font-semibold opacity-90">
        {totalGuias} guías · 1 proyecto
      </span>
      <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"></path>
        <path d="m12 5 7 7-7 7"></path>
      </svg>
    </div>
  </div>
</a>

---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import OnboardingGrado from '../components/OnboardingGrado.astro';
import BuscadorOverlay from '../components/BuscadorOverlay.astro';
import OfflineIndicator from '../components/OfflineIndicator.astro';

interface Props {
  title?: string;
  description?: string;
  /** Imagen para Open Graph y Twitter Card. Ruta relativa al `base` (ej. "/og/grado-6.png") o URL absoluta. */
  imagen?: string;
  /** Tipo Open Graph; "website" para landings, "article" para guías */
  ogType?: 'website' | 'article';
}

const {
  title = 'ConectaTE — Conectando Tecnología con Educación',
  description = 'Plataforma educativa del Dr. Álvaro Cárdenas Orozco — I.E. Sor María Juliana, Cartago. 180 guías de Tecnología e Informática para grados 6° a 11°.',
  imagen,
  ogType = 'website',
} = Astro.props;

const base = import.meta.env.BASE_URL;

// URL canónica de la página actual
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://alguarito.github.io').toString();

// Imagen OG: si no se pasó una específica, usamos /og/home.png (1200×630)
const ogImageRel = imagen ?? '/og/home.png';
const ogImageUrl = ogImageRel.startsWith('http')
  ? ogImageRel
  : new URL(`${base}${ogImageRel}`.replace(/\/+/g, '/'), Astro.site ?? 'https://alguarito.github.io').toString();
// Las imágenes de /og/ son 1200×630; el LOGO.png antiguo era 1024×1024
const isFullsizeOg = !ogImageRel.includes('LOGO.png');
const ogImageWidth = isFullsizeOg ? 1200 : 1024;
const ogImageHeight = isFullsizeOg ? 630 : 1024;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#FAFAFA" media="(prefers-color-scheme: light)" />
    <title>{title}</title>

    <!-- Iconos / PWA -->
    <link rel="icon" type="image/png" href={`${base}/LOGO.png`} />
    <link rel="apple-touch-icon" href={`${base}/LOGO.png`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, WhatsApp, Telegram, LinkedIn, Discord, etc.) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="ConectaTE" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content="ConectaTE — Plataforma educativa" />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter Card (X, también lo respetan otros clientes) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Datos del autor -->
    <meta name="author" content="Dr. Álvaro Cárdenas Orozco" />

    <!-- Inter variable font -->
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <!-- Script modo oscuro - antes del render -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body class="min-h-screen">
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
    <OnboardingGrado />
    <BuscadorOverlay />
    <OfflineIndicator />

    <!-- Service Worker: registra para funcionamiento offline -->
    <script is:inline define:vars={{ swPath: `${base}/sw.js`.replace(/\/+/g, '/'), swScope: `${base}/`.replace(/\/+/g, '/') }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register(swPath, { scope: swScope })
            .catch((err) => console.warn('[ConectaTE] Service Worker no se registró:', err));
        });
      }
    </script>
  </body>
</html>

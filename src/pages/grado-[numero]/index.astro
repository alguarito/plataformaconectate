---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PeriodoCard from '../../components/PeriodoCard.astro';
import { grados } from '../../data/grados';

export function getStaticPaths() {
  return grados.map((g) => ({
    params: { numero: String(g.numero) },
    props: { grado: g },
  }));
}

const { grado } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`Grado ${grado.numero}° — ${grado.titulo} · ConectaTE`}>
  <!-- Header del grado -->
  <section class="pt-12 pb-12">
    <div class="bento-container">
      <a
        href={base || '/'}
        class="inline-flex items-center gap-2 text-sm font-semibold mb-8 hover:opacity-60 transition-opacity"
        style="color: var(--fg-muted);"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
        Inicio
      </a>

      <!-- Hero del grado: card grande de color + info al lado -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 mb-10">
        <!-- Card grande de color con número -->
        <div class={`bento-card-color ${grado.bgClass} md:col-span-5 flex flex-col justify-between min-h-[320px]`}>
          <div class="flex items-start justify-between">
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">Grado</span>
            <span class="text-7xl">{grado.icono}</span>
          </div>
          <div class="text-[12rem] md:text-[14rem] font-black tracking-tighter leading-none -mb-4">
            {grado.numero}°
          </div>
        </div>

        <!-- Info -->
        <div class="md:col-span-7 flex flex-col justify-center">
          <span class="chip-bento mb-4 self-start">Tecnología e Informática</span>
          <h1 class="heading-giant text-balance mb-4">{grado.titulo}</h1>
          <p class="text-lg md:text-xl text-balance leading-relaxed" style="color: var(--fg-muted);">
            {grado.descripcion}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Períodos -->
  <section class="pb-24">
    <div class="bento-container">
      <div class="mb-8">
        <span class="chip-bento mb-3">3 Períodos</span>
        <h2 class="heading-huge">Estructura del año.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
        {
          grado.periodos.map((p) => (
            <PeriodoCard
              numero={p.numero}
              titulo={p.titulo}
              descripcion={p.descripcion}
              bgClass={p.bgClass}
              totalGuias={p.totalGuias}
              grado={grado.numero}
              href={`${base}/grado-${grado.numero}/periodo-${p.numero}`}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

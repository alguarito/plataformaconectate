---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CompletarBoton from '../../../../components/CompletarBoton.astro';
import CompartirWhatsApp from '../../../../components/CompartirWhatsApp.astro';
import LabQuiz from '../../../../components/LabQuiz.astro';
import LabVisualizacion from '../../../../components/LabVisualizacion.astro';
import { grados } from '../../../../data/grados';
import {
  getRecurso,
  pdfPreviewUrl,
  pdfDownloadUrl,
  pdfViewUrl,
} from '../../../../data/recursos';
import { getContenidoGuia } from '../../../../data/guiasContenido/_index';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const g of grados) {
    for (const p of g.periodos) {
      for (let s = 1; s <= 10; s++) {
        paths.push({
          params: {
            numero: String(g.numero),
            periodo: String(p.numero),
            guia: String(s),
          },
          props: { grado: g, periodo: p, sesion: s },
        });
      }
    }
  }
  return paths;
}

const { grado, periodo, sesion } = Astro.props;
const base = import.meta.env.BASE_URL;

// Recurso real desde Drive (titulo + pdfId)
const recurso = getRecurso(grado.numero, periodo.numero, sesion);
const tituloGuia = recurso?.titulo ?? `Guía ${sesion}`;
const pdfId = recurso?.pdfId ?? '';
const previewUrl = pdfId ? pdfPreviewUrl(pdfId) : '';
const downloadUrl = pdfId ? pdfDownloadUrl(pdfId) : '';
const viewUrl = pdfId ? pdfViewUrl(pdfId) : '';

// Contenido enriquecido (si existe para esta guía)
const enriquecida = getContenidoGuia(grado.numero, periodo.numero, sesion);

// Navegación previa/siguiente
const prevSesion = sesion > 1 ? sesion - 1 : null;
const nextSesion = sesion < 10 ? sesion + 1 : null;
---

<BaseLayout
  title={`Sesión ${sesion} · ${tituloGuia} — ConectaTE`}
  description={`Grado ${grado.numero}° · Período ${periodo.numero} · ${periodo.titulo}. Guía con visor PDF embebido y descarga directa.`}
  ogType="article"
  imagen={`/og/grado-${grado.numero}-periodo-${periodo.numero}.png`}
>
  <article class="pt-12 pb-20">
    <div class="bento-container max-w-5xl">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm font-semibold mb-8 flex-wrap" style="color: var(--fg-muted);">
        <a href={base || '/'} class="hover:opacity-60 transition-opacity">Inicio</a>
        <span>/</span>
        <a href={`${base}/grado-${grado.numero}`} class="hover:opacity-60 transition-opacity">
          Grado {grado.numero}°
        </a>
        <span>/</span>
        <a href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}`} class="hover:opacity-60 transition-opacity">
          Período {periodo.numero}
        </a>
        <span>/</span>
        <span style="color: var(--fg);">Sesión {sesion}</span>
      </nav>

      <!-- Hero card de la guía -->
      <div class={`bento-card-color ${periodo.bgClass} mb-10 min-h-[340px] flex flex-col justify-between`}>
        <div class="flex items-start justify-between flex-wrap gap-3">
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              Grado {grado.numero}°
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              Período {periodo.numero}
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              ⏱ {enriquecida ? `${enriquecida.duracionMin} min` : '2 horas'}
            </span>
            {enriquecida && (
              <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-bento-lime text-black">
                ✨ Enriquecida
              </span>
            )}
          </div>
          <span class="text-[10rem] md:text-[12rem] font-black tracking-tighter leading-none opacity-25 -mr-4 -my-4">
            {sesion}
          </span>
        </div>

        <div>
          <span class="text-xs font-bold uppercase tracking-widest opacity-80">
            Sesión {sesion} · {periodo.titulo}{enriquecida?.subtema ? ` · ${enriquecida.subtema}` : ''}
          </span>
          <h1 class="heading-giant text-balance mt-2">
            {tituloGuia}
          </h1>
          {enriquecida && (
            <p class="text-base md:text-lg opacity-90 leading-snug mt-3 max-w-2xl">
              {enriquecida.resumen}
            </p>
          )}
        </div>
      </div>

      {pdfId && (
        <>
          <!-- Acciones rápidas: descargar / abrir en Drive -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-10">
            <a
              href={downloadUrl}
              class="bento-card-color bg-bento-lime flex items-center gap-4 hover:scale-[1.01] transition-transform group"
            >
              <div class="text-5xl">⬇️</div>
              <div class="flex-1">
                <span class="text-xs font-bold uppercase tracking-widest opacity-80">PDF</span>
                <div class="font-black text-xl leading-tight mt-1">Descargar guía</div>
                <div class="text-sm opacity-80 mt-1">Llévala contigo en cualquier dispositivo</div>
              </div>
              <svg class="w-7 h-7 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>

            <a
              href={viewUrl}
              target="_blank"
              rel="noopener"
              class="bento-card-hover flex items-center gap-4"
            >
              <div class="text-5xl">📂</div>
              <div class="flex-1">
                <span class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">Drive</span>
                <div class="font-black text-xl leading-tight mt-1">Abrir en Drive</div>
                <div class="text-sm mt-1" style="color: var(--fg-muted);">Versión completa con anotaciones</div>
              </div>
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
          </div>

          {/* ═══ PRE-LECTURA (solo si la guía está enriquecida) ═══ */}
          {enriquecida && (
            <>
              <!-- Por qué importa + pregunta detonante -->
              <div class="bento-card-color bg-bento-yellow mb-6 flex items-start gap-4">
                <div class="text-5xl shrink-0">💡</div>
                <div>
                  <span class="text-xs font-bold uppercase tracking-widest opacity-80">
                    Antes de empezar · Por qué importa
                  </span>
                  <p class="text-base md:text-lg leading-relaxed mt-2 mb-4">
                    {enriquecida.preLectura.porQueImporta}
                  </p>
                  <div class="border-t border-black/15 pt-3 mt-3">
                    <span class="text-xs font-bold uppercase tracking-widest opacity-80">
                      Pregunta para arrancar
                    </span>
                    <p class="font-black text-lg md:text-xl mt-1">
                      "{enriquecida.preLectura.preguntaDetonante}"
                    </p>
                  </div>
                </div>
              </div>

              <!-- Activación + conexión con sesiones -->
              <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 mb-6">
                <div class="bento-card md:col-span-7">
                  <span class="chip-bento mb-3">🔥 Calienta motores</span>
                  <h3 class="text-lg md:text-xl font-black tracking-tight leading-tight mb-2">
                    {enriquecida.preLectura.activacion.titulo}
                  </h3>
                  <p class="text-sm md:text-base leading-relaxed mb-3" style="color: var(--fg-muted);">
                    {enriquecida.preLectura.activacion.descripcion}
                  </p>
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-bento-blue text-white">
                    ⏱ {enriquecida.preLectura.activacion.duracionMin} min
                  </span>
                </div>

                <div class="md:col-span-5 space-y-4">
                  {enriquecida.preLectura.conexion.anterior && (
                    <div class="bento-card">
                      <span class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">
                        ← Vienes de
                      </span>
                      <p class="text-sm leading-relaxed mt-2">
                        {enriquecida.preLectura.conexion.anterior}
                      </p>
                    </div>
                  )}
                  {enriquecida.preLectura.conexion.siguiente && (
                    <div class="bento-card">
                      <span class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">
                        Vas hacia →
                      </span>
                      <p class="text-sm leading-relaxed mt-2">
                        {enriquecida.preLectura.conexion.siguiente}
                      </p>
                    </div>
                  )}
                </div>
              </div>

              <!-- Conceptos clave -->
              <div class="bento-card mb-10">
                <span class="chip-bento mb-3">📚 Vocabulario clave</span>
                <h3 class="heading-huge mb-2 leading-tight">
                  Las {enriquecida.conceptosClave.length} palabras que vas a entender hoy.
                </h3>
                <p class="text-sm md:text-base leading-relaxed mb-6" style="color: var(--fg-muted);">
                  Domina estas ideas y todo lo demás cae solo. Léelas antes de abrir el PDF.
                </p>
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {enriquecida.conceptosClave.map((c, i) => (
                    <li class="p-4 rounded-bento-sm border-2" style="border-color: var(--border);">
                      <div class="flex items-baseline gap-2 mb-2">
                        {c.emoji && <span class="text-2xl">{c.emoji}</span>}
                        <h4 class="font-black text-base md:text-lg">{c.termino}</h4>
                      </div>
                      <p class="text-sm leading-relaxed mb-2">{c.definicion}</p>
                      <p class="text-xs leading-relaxed italic p-2 rounded-md" style="background: var(--bg); color: var(--fg-muted);">
                        <strong style="color: var(--fg);">Ej.</strong> {c.ejemplo}
                      </p>
                    </li>
                  ))}
                </ul>
              </div>
            </>
          )}

          <!-- Visor PDF embebido -->
          <div class="bento-card mb-10 p-0 overflow-hidden">
            <div class="px-6 py-4 border-b" style="border-color: var(--border);">
              <div class="flex items-center justify-between gap-3 flex-wrap">
                <div>
                  <span class="chip-bento">Guía completa · PDF</span>
                </div>
                <div class="text-sm font-semibold" style="color: var(--fg-muted);">
                  {recurso?.guiaId}
                </div>
              </div>
            </div>
            <div class="aspect-[8.5/11] md:aspect-[3/4] w-full bg-black/5">
              <iframe
                src={previewUrl}
                class="w-full h-full"
                loading="lazy"
                allow="autoplay"
                title={`Visor PDF — ${tituloGuia}`}
              ></iframe>
            </div>
          </div>

          {/* ═══ POST-LECTURA: laboratorios + reflexión ═══ */}
          {enriquecida && (
            <>
              <!-- Encabezado de laboratorios -->
              <div class="bento-card-color bg-bento-lime mb-6 text-center py-8 px-6">
                <div class="text-5xl mb-2">🧪</div>
                <h2 class="heading-huge leading-tight mb-2">
                  Ahora aplica lo aprendido.
                </h2>
                <p class="text-base md:text-lg leading-relaxed max-w-2xl mx-auto">
                  Tienes el PDF leído. Aquí pones las manos. Estos labs te ayudan
                  a verificar que entendiste antes de la próxima clase.
                </p>
              </div>

              <!-- Cada laboratorio -->
              <div class="space-y-6 mb-10">
                {enriquecida.laboratorios.map((lab, idx) => {
                  if (lab.tipo === 'quiz') {
                    return <LabQuiz data={lab} id={`lab-${idx}-quiz`} />;
                  }
                  if (lab.tipo === 'visualizacion') {
                    return <LabVisualizacion data={lab} id={`lab-${idx}-viz`} />;
                  }
                  return null;
                })}
              </div>

              <!-- Reflexión, transferencia y cierre MILC -->
              <div class="bento-card-color bg-bento-purple mb-10">
                <span class="text-xs font-bold uppercase tracking-widest opacity-80">
                  🪞 Cierre · Evaluación liberadora
                </span>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
                  <div>
                    <h3 class="font-black text-lg mb-2">Reflexión</h3>
                    <p class="text-sm md:text-base leading-relaxed opacity-95">
                      {enriquecida.postLectura.reflexion}
                    </p>
                  </div>
                  <div>
                    <h3 class="font-black text-lg mb-2">Transferencia a tu vida</h3>
                    <p class="text-sm md:text-base leading-relaxed opacity-95">
                      {enriquecida.postLectura.transferencia}
                    </p>
                  </div>
                </div>
                <div class="mt-6 pt-6 border-t border-white/15">
                  <p class="text-sm md:text-base italic leading-relaxed opacity-95">
                    {enriquecida.postLectura.cierre}
                  </p>
                </div>
              </div>
            </>
          )}
        </>
      )}

      {!pdfId && (
        <div class="bento-card-color bg-bento-yellow mb-10 flex items-start gap-4">
          <div class="text-5xl">📝</div>
          <div>
            <h3 class="text-xl font-black tracking-tight mb-1">PDF en preparación</h3>
            <p class="opacity-80 leading-relaxed">
              Esta guía aún no tiene PDF publicado. Estará disponible muy pronto.
            </p>
          </div>
        </div>
      )}

      <CompletarBoton tipo="guia" grado={grado.numero} periodo={periodo.numero} sesion={sesion} />

      <CompartirWhatsApp
        titulo={tituloGuia}
        contexto={`Grado ${grado.numero}° · P${periodo.numero} · Sesión ${sesion}`}
      />

      <!-- Estructura de la sesión -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-6">Estructura de la sesión</span>

        <div class="space-y-6 mt-6">
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-bento-sm bg-bento-blue text-white flex items-center justify-center text-xl font-black shrink-0">1</div>
            <div>
              <h3 class="text-xl font-black mb-1">Introducción</h3>
              <p class="leading-relaxed" style="color: var(--fg-muted);">
                Activación de conocimientos previos y planteamiento del problema o pregunta orientadora.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-bento-sm bg-bento-orange text-white flex items-center justify-center text-xl font-black shrink-0">2</div>
            <div>
              <h3 class="text-xl font-black mb-1">Desarrollo conceptual</h3>
              <p class="leading-relaxed" style="color: var(--fg-muted);">
                Explicación de los contenidos de la sesión con ejemplos, recursos visuales y referencias.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-bento-sm bg-bento-lime text-black flex items-center justify-center text-xl font-black shrink-0">3</div>
            <div>
              <h3 class="text-xl font-black mb-1">Actividad práctica</h3>
              <p class="leading-relaxed" style="color: var(--fg-muted);">
                Ejercicio individual o colaborativo donde aplicas lo aprendido.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-bento-sm bg-bento-pink text-white flex items-center justify-center text-xl font-black shrink-0">4</div>
            <div>
              <h3 class="text-xl font-black mb-1">Evaluación</h3>
              <p class="leading-relaxed" style="color: var(--fg-muted);">
                Cuestionario interactivo, producto o reflexión escrita para evidenciar el aprendizaje.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Navegación previa / siguiente -->
      <nav class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
        {prevSesion ? (
          <a
            href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}/guia-${prevSesion}`}
            class="bento-card-hover flex items-center gap-4"
          >
            <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5"></path>
              <path d="m12 19-7-7 7-7"></path>
            </svg>
            <div>
              <div class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">Anterior</div>
              <div class="font-black text-lg">Sesión {prevSesion}</div>
            </div>
          </a>
        ) : (
          <a
            href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}`}
            class="bento-card-hover flex items-center gap-4"
          >
            <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5"></path>
              <path d="m12 19-7-7 7-7"></path>
            </svg>
            <div>
              <div class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">Volver al</div>
              <div class="font-black text-lg">Período {periodo.numero}</div>
            </div>
          </a>
        )}

        {nextSesion ? (
          <a
            href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}/guia-${nextSesion}`}
            class="bento-card-hover flex items-center gap-4 justify-end text-right"
          >
            <div>
              <div class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">Siguiente</div>
              <div class="font-black text-lg">Sesión {nextSesion}</div>
            </div>
            <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        ) : (
          <a
            href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}/proyecto`}
            class={`bento-card-color ${periodo.bgClass} flex items-center gap-4 justify-end text-right`}
          >
            <div>
              <div class="text-xs font-bold uppercase tracking-widest opacity-80">Continúa con el</div>
              <div class="font-black text-lg">Proyecto integrador</div>
            </div>
            <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        )}
      </nav>
    </div>
  </article>
</BaseLayout>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { grados } from '../../../data/grados';
import { getRecurso } from '../../../data/recursos';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const g of grados) {
    for (const p of g.periodos) {
      paths.push({
        params: { numero: String(g.numero), periodo: String(p.numero) },
        props: { grado: g, periodo: p },
      });
    }
  }
  return paths;
}

const { grado, periodo } = Astro.props;
const base = import.meta.env.BASE_URL;

const guias = Array.from({ length: 10 }, (_, i) => {
  const sesion = i + 1;
  const recurso = getRecurso(grado.numero, periodo.numero, sesion);
  return {
    numero: sesion,
    titulo: recurso?.titulo ?? `Sesión ${sesion}`,
    href: `${base}/grado-${grado.numero}/periodo-${periodo.numero}/guia-${sesion}`,
  };
});
---

<BaseLayout
  title={`Grado ${grado.numero}° · Período ${periodo.numero}: ${periodo.titulo} — ConectaTE`}
  description={`${periodo.descripcion} · 10 guías + 1 proyecto integrador del grado ${grado.numero}°.`}
>
  <section class="pt-12 pb-12">
    <div class="bento-container">
      <a
        href={`${base}/grado-${grado.numero}`}
        class="inline-flex items-center gap-2 text-sm font-semibold mb-8 hover:opacity-60 transition-opacity"
        style="color: var(--fg-muted);"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
        Grado {grado.numero}°
      </a>

      <!-- Hero del período -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 mb-10">
        <div class={`bento-card-color ${periodo.bgClass} md:col-span-4 flex flex-col justify-between min-h-[280px]`}>
          <span class="text-xs font-bold uppercase tracking-widest opacity-80">Período</span>
          <div class="text-[14rem] font-black tracking-tighter leading-none -mb-4">
            {periodo.numero}
          </div>
        </div>

        <div class="md:col-span-8 flex flex-col justify-center">
          <span class="chip-bento mb-4 self-start">Grado {grado.numero}°</span>
          <h1 class="heading-giant text-balance mb-4">{periodo.titulo}</h1>
          <p class="text-lg md:text-xl text-balance leading-relaxed" style="color: var(--fg-muted);">
            {periodo.descripcion}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Guías como Bento Grid -->
  <section class="pb-12">
    <div class="bento-container">
      <div class="mb-8 flex items-end justify-between gap-4 flex-wrap">
        <div>
          <span class="chip-bento mb-3">10 Sesiones</span>
          <h2 class="heading-huge">Guías de aprendizaje.</h2>
        </div>
        <div
          class="hidden text-right"
          data-progreso-periodo
          data-grado={grado.numero}
          data-periodo={periodo.numero}
        >
          <div class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">
            Tu progreso · período
          </div>
          <div class="text-2xl font-black tracking-tight mt-1">
            <span data-pp-completas>0</span>/10 guías
            <span class="text-sm font-bold opacity-70 ml-1" data-pp-proyecto-tag></span>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
        {
          guias.map((g) => (
            <a
              href={g.href}
              data-sesion-card
              data-grado={grado.numero}
              data-periodo={periodo.numero}
              data-sesion={g.numero}
              class="bento-card-hover flex gap-4 items-start group relative"
            >
              <span class="text-5xl md:text-6xl font-black tracking-tighter leading-none shrink-0 group-hover:scale-110 transition-transform" style="color: var(--fg-muted); opacity: 0.4;">
                {g.numero}
              </span>
              <div class="flex-1 min-w-0">
                <span class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">
                  Sesión {g.numero}
                </span>
                <h3 class="font-black text-base md:text-lg leading-tight mt-1 line-clamp-3">
                  {g.titulo}
                </h3>
              </div>
              <span
                data-sesion-check
                class="hidden absolute top-3 right-3 w-7 h-7 rounded-full bg-bento-lime text-black flex items-center justify-center text-sm font-black shrink-0"
                aria-label="Completada"
              >✓</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    import { progresoPeriodo, estaGuiaCompletada, onCambio } from '../../../scripts/progreso';

    function render() {
      // Marca tarjetas de sesión completadas
      document.querySelectorAll<HTMLElement>('[data-sesion-card]').forEach((card) => {
        const g = parseInt(card.dataset.grado || '0', 10);
        const p = parseInt(card.dataset.periodo || '0', 10);
        const s = parseInt(card.dataset.sesion || '0', 10);
        const check = card.querySelector<HTMLElement>('[data-sesion-check]');
        if (estaGuiaCompletada(g, p, s)) {
          check?.classList.remove('hidden');
          check?.classList.add('flex');
          card.classList.add('ring-2', 'ring-bento-lime/50');
        } else {
          check?.classList.add('hidden');
          check?.classList.remove('flex');
          card.classList.remove('ring-2', 'ring-bento-lime/50');
        }
      });

      // Resumen del período
      const wrap = document.querySelector<HTMLElement>('[data-progreso-periodo]');
      if (wrap) {
        const g = parseInt(wrap.dataset.grado || '0', 10);
        const p = parseInt(wrap.dataset.periodo || '0', 10);
        const r = progresoPeriodo(g, p);
        const completas = wrap.querySelector<HTMLElement>('[data-pp-completas]');
        const tag = wrap.querySelector<HTMLElement>('[data-pp-proyecto-tag]');
        if (completas) completas.textContent = String(r.guiasCompletadas);
        if (tag) tag.textContent = r.proyectoCompletado ? '· proyecto ✓' : '';
        if (r.guiasCompletadas > 0 || r.proyectoCompletado) {
          wrap.classList.remove('hidden');
        } else {
          wrap.classList.add('hidden');
        }
      }
    }
    render();
    onCambio(render);
  </script>

  <!-- Proyecto integrador + Examen -->
  <section class="pb-24">
    <div class="bento-container">
      <div class="mb-6">
        <span class="chip-bento mb-3">Cierre del período</span>
        <h2 class="heading-huge">Aplica y demuestra.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
        <!-- Proyecto integrador -->
        <a
          href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}/proyecto`}
          class={`bento-card-color ${periodo.bgClass} md:col-span-7 flex flex-col md:flex-row md:items-center gap-4 md:gap-6 hover:scale-[1.01] transition-transform group min-h-[260px]`}
        >
          <div class="text-8xl md:text-9xl">🎯</div>
          <div class="flex-1">
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">
              Proyecto Integrador
            </span>
            <h3 class="text-2xl md:text-3xl font-black tracking-tight mt-2 mb-3 leading-tight">
              {periodo.titulo}
            </h3>
            <p class="opacity-80 leading-relaxed text-sm md:text-base">
              Crea un producto real que integre todo lo aprendido. Diseño, prototipado y validación con la comunidad.
            </p>
            <div class="inline-flex items-center gap-2 font-bold text-sm mt-3 group-hover:gap-3 transition-all">
              Ver proyecto
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </a>

        <!-- Examen final -->
        <a
          href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}/examen`}
          class="bento-card-color bg-bento-black md:col-span-5 flex flex-col gap-4 hover:scale-[1.01] transition-transform group min-h-[260px] grid-pattern"
        >
          <div class="text-7xl md:text-8xl">📝</div>
          <div class="flex-1 flex flex-col justify-end">
            <span class="text-xs font-bold uppercase tracking-widest opacity-70">
              Examen Final
            </span>
            <h3 class="text-2xl md:text-3xl font-black tracking-tight mt-2 mb-3 leading-tight">
              Síntesis · Aplicación
            </h3>
            <p class="opacity-70 leading-relaxed text-sm">
              Verifica la transferencia de las 10 sesiones del período.
            </p>
            <div class="inline-flex items-center gap-2 font-bold text-sm mt-3 group-hover:gap-3 transition-all">
              Ver examen
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

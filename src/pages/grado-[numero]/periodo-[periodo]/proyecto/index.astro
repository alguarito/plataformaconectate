---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CompletarBoton from '../../../../components/CompletarBoton.astro';
import CompartirWhatsApp from '../../../../components/CompartirWhatsApp.astro';
import { grados } from '../../../../data/grados';
import { getProyecto } from '../../../../data/proyectos';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const g of grados) {
    for (const p of g.periodos) {
      paths.push({
        params: { numero: String(g.numero), periodo: String(p.numero) },
        props: { grado: g, periodo: p },
      });
    }
  }
  return paths;
}

const { grado, periodo } = Astro.props;
const base = import.meta.env.BASE_URL;

// Datos reales del proyecto desde proyectos.ts
const proyecto = getProyecto(grado.numero, periodo.numero);

// URL de descarga del PDF servido localmente
const pdfHref = proyecto ? `${base}/proyectos/${proyecto.pdf}` : '';
---

<BaseLayout
  title={`Proyecto Integrador · Grado ${grado.numero}° P${periodo.numero}: ${periodo.titulo} — ConectaTE`}
  description={proyecto?.retoCentral ?? `Aplica todo lo aprendido en el período ${periodo.numero}: ${periodo.titulo}.`}
  ogType="article"
  imagen={`/og/grado-${grado.numero}-periodo-${periodo.numero}.png`}
>
  <article class="pt-12 pb-20">
    <div class="bento-container max-w-5xl">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm font-semibold mb-8 flex-wrap" style="color: var(--fg-muted);">
        <a href={base || '/'} class="hover:opacity-60 transition-opacity">Inicio</a>
        <span>/</span>
        <a href={`${base}/grado-${grado.numero}`} class="hover:opacity-60 transition-opacity">
          Grado {grado.numero}°
        </a>
        <span>/</span>
        <a href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}`} class="hover:opacity-60 transition-opacity">
          Período {periodo.numero}
        </a>
        <span>/</span>
        <span style="color: var(--fg);">Proyecto integrador</span>
      </nav>

      <!-- Hero card del proyecto -->
      <div class={`bento-card-color ${periodo.bgClass} mb-10 min-h-[360px] flex flex-col justify-between`}>
        <div class="flex items-start justify-between flex-wrap gap-3">
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              Grado {grado.numero}°
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              Período {periodo.numero}
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              🎯 Proyecto integrador
            </span>
          </div>
          <span class="text-9xl">🎯</span>
        </div>

        <div>
          <span class="text-xs font-bold uppercase tracking-widest opacity-80">
            Proyecto Integrador · {periodo.titulo}
          </span>
          <h1 class="heading-giant text-balance mt-2 mb-4">
            {proyecto?.retoCentral ?? 'Aplica todo lo aprendido.'}
          </h1>
          {proyecto?.estrategia && (
            <p class="text-sm md:text-base font-semibold opacity-90 max-w-2xl">
              <strong>Estrategia:</strong> {proyecto.estrategia}
            </p>
          )}
        </div>
      </div>

      {proyecto && (
        <>
          <!-- Acciones rápidas: descargar PDF -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-10">
            <a
              href={pdfHref}
              download
              class="bento-card-color bg-bento-lime flex items-center gap-4 hover:scale-[1.01] transition-transform group"
            >
              <div class="text-5xl">📄</div>
              <div class="flex-1">
                <span class="text-xs font-bold uppercase tracking-widest opacity-80">PDF imprimible</span>
                <div class="font-black text-xl leading-tight mt-1">Descargar plantilla</div>
                <div class="text-sm opacity-80 mt-1">Versión imprimible con espacios para llenar</div>
              </div>
              <svg class="w-7 h-7 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
            </a>

            <a
              href={pdfHref}
              target="_blank"
              rel="noopener"
              class="bento-card-hover flex items-center gap-4"
            >
              <div class="text-5xl">👁️</div>
              <div class="flex-1">
                <span class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">Vista previa</span>
                <div class="font-black text-xl leading-tight mt-1">Abrir en pestaña nueva</div>
                <div class="text-sm mt-1" style="color: var(--fg-muted);">Para revisarlo antes de descargar</div>
              </div>
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
          </div>

          {proyecto.sentido && (
            <!-- Sentido del proyecto -->
            <div class="bento-card mb-10">
              <span class="chip-bento mb-4">Sentido del proyecto</span>
              <p class="text-base md:text-lg leading-relaxed mt-3">
                {proyecto.sentido}
              </p>
            </div>
          )}

          <!-- Bento de información clave -->
          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 mb-10">
            <!-- Producto final -->
            <div class="bento-card-color bg-bento-purple md:col-span-7 min-h-[200px] flex flex-col justify-between">
              <span class="text-xs font-bold uppercase tracking-widest opacity-80">Producto final</span>
              <div>
                <div class="text-xl md:text-2xl font-black tracking-tight leading-tight">
                  {proyecto.productoFinal}
                </div>
              </div>
            </div>

            <!-- Foco de diseño -->
            <div class="bento-card-color bg-bento-cyan md:col-span-5 min-h-[200px] flex flex-col justify-between">
              <span class="text-xs font-bold uppercase tracking-widest opacity-80">Foco de diseño</span>
              <div>
                <div class="text-base md:text-lg font-black tracking-tight leading-tight">
                  {proyecto.focoDiseno}
                </div>
              </div>
            </div>

            <!-- DBA -->
            <div class="bento-card-color bg-bento-yellow md:col-span-12 min-h-[140px] flex flex-col justify-between">
              <span class="text-xs font-bold uppercase tracking-widest opacity-80">DBA del periodo</span>
              <div class="text-base md:text-lg font-bold leading-relaxed">
                {proyecto.dba}
              </div>
            </div>
          </div>

          {proyecto.aprendizajes.length > 0 && (
            <!-- Aprendizajes que integra -->
            <div class="bento-card mb-10">
              <span class="chip-bento mb-4">Aprendizajes que integra</span>
              <p class="text-sm mt-3 mb-5" style="color: var(--fg-muted);">
                Las 10 sesiones del período cuyas competencias se ponen en juego en este proyecto.
              </p>
              <ul class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-4">
                {proyecto.aprendizajes.map((a, i) => (
                  <li class="flex items-start gap-3">
                    <span class="w-7 h-7 rounded-bento-sm bg-bento-blue text-white flex items-center justify-center text-xs font-black shrink-0 mt-0.5">
                      {i + 1}
                    </span>
                    <span class="text-sm leading-relaxed">{a}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Fases del proyecto -->
          <div class="bento-card mb-10">
            <span class="chip-bento mb-6">Fases del proyecto · método MILC</span>
            <p class="text-sm mb-2 mt-2" style="color: var(--fg-muted);">
              Recorrido en cuatro fases: Escuta, Sistematización, Praxis y Evaluación liberadora.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
              {[
                { color: 'bg-bento-lime', textColor: 'text-black', n: 1 },
                { color: 'bg-bento-cyan', textColor: 'text-white', n: 2 },
                { color: 'bg-bento-pink', textColor: 'text-white', n: 3 },
                { color: 'bg-bento-purple', textColor: 'text-white', n: 4 },
              ].map(({ color, textColor, n }, i) => {
                const fase = proyecto.fases[i];
                return (
                  <div class="flex gap-4">
                    <div class={`w-12 h-12 rounded-bento-sm ${color} ${textColor} flex items-center justify-center text-xl font-black shrink-0`}>
                      {n}
                    </div>
                    <div class="flex-1">
                      <h3 class="text-lg font-black mb-1 leading-tight">{fase.nombre}</h3>
                      <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
                        {fase.proposito}
                      </p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          {(proyecto.conceptosClave || proyecto.competencias) && (
            <!-- Conceptos / Competencias / Desempeños -->
            <div class="bento-card mb-10">
              <span class="chip-bento mb-4">Conceptos, competencias y desempeños</span>
              <div class="space-y-4 mt-5">
                {proyecto.conceptosClave && (
                  <div>
                    <h4 class="text-sm font-black uppercase tracking-widest mb-1" style="color: var(--fg-muted);">Conceptos clave</h4>
                    <p class="text-sm md:text-base leading-relaxed">{proyecto.conceptosClave}</p>
                  </div>
                )}
                {proyecto.competencias && (
                  <div>
                    <h4 class="text-sm font-black uppercase tracking-widest mb-1" style="color: var(--fg-muted);">Competencias</h4>
                    <p class="text-sm md:text-base leading-relaxed">{proyecto.competencias}</p>
                  </div>
                )}
                {proyecto.desempenoCognitivo && (
                  <div>
                    <h4 class="text-sm font-black uppercase tracking-widest mb-1" style="color: var(--fg-muted);">Desempeño cognitivo</h4>
                    <p class="text-sm md:text-base leading-relaxed">{proyecto.desempenoCognitivo}</p>
                  </div>
                )}
                {proyecto.desempenoProcedimental && (
                  <div>
                    <h4 class="text-sm font-black uppercase tracking-widest mb-1" style="color: var(--fg-muted);">Desempeño procedimental</h4>
                    <p class="text-sm md:text-base leading-relaxed">{proyecto.desempenoProcedimental}</p>
                  </div>
                )}
                {proyecto.desempenoActitudinal && (
                  <div>
                    <h4 class="text-sm font-black uppercase tracking-widest mb-1" style="color: var(--fg-muted);">Desempeño actitudinal</h4>
                    <p class="text-sm md:text-base leading-relaxed">{proyecto.desempenoActitudinal}</p>
                  </div>
                )}
              </div>
            </div>
          )}

          {proyecto.entregables.length > 0 && (
            <!-- Entregables mínimos -->
            <div class="bento-card-color bg-bento-orange mb-10">
              <span class="chip-bento mb-4 bg-black/15">Entregables mínimos</span>
              <ul class="space-y-3 mt-4">
                {proyecto.entregables.map((e) => (
                  <li class="flex items-start gap-3">
                    <span class="w-6 h-6 rounded-md border-2 border-current flex items-center justify-center shrink-0 mt-0.5">
                      <span class="text-xs font-black">✓</span>
                    </span>
                    <span class="text-base leading-relaxed">{e}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {proyecto.rubrica.length > 0 && (
            <!-- Rúbrica de evaluación -->
            <div class="bento-card mb-10">
              <span class="chip-bento mb-4">Rúbrica de evaluación</span>
              <p class="text-sm mt-2 mb-5" style="color: var(--fg-muted);">
                Niveles de desempeño por criterio · Excelente (5) · Aceptable (3) · Por mejorar (1)
              </p>
              <div class="overflow-x-auto -mx-6 md:mx-0">
                <table class="w-full text-sm border-separate border-spacing-0 min-w-[640px] md:min-w-0">
                  <thead>
                    <tr>
                      <th class="text-left p-3 align-top font-black uppercase tracking-widest text-xs" style="color: var(--fg-muted);">Criterio</th>
                      <th class="text-left p-3 align-top">
                        <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-bento-lime text-black text-xs font-black">5 Excelente</span>
                      </th>
                      <th class="text-left p-3 align-top">
                        <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-bento-yellow text-black text-xs font-black">3 Aceptable</span>
                      </th>
                      <th class="text-left p-3 align-top">
                        <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-bento-pink text-white text-xs font-black">1 Por mejorar</span>
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {proyecto.rubrica.map((r, i) => (
                      <tr class={i % 2 === 1 ? 'bg-black/[0.02] dark:bg-white/[0.02]' : ''}>
                        <td class="p-3 align-top font-bold border-t" style="border-color: var(--border);">
                          {r.criterio}
                        </td>
                        <td class="p-3 align-top leading-relaxed border-t" style="border-color: var(--border);">
                          {r.nivel5}
                        </td>
                        <td class="p-3 align-top leading-relaxed border-t" style="border-color: var(--border);">
                          {r.nivel3}
                        </td>
                        <td class="p-3 align-top leading-relaxed border-t" style="border-color: var(--border);">
                          {r.nivel1}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          <!-- Marca como completado y comparte -->
          <CompletarBoton tipo="proyecto" grado={grado.numero} periodo={periodo.numero} />

          <CompartirWhatsApp
            titulo={`Proyecto Integrador · ${periodo.titulo}`}
            contexto={`Grado ${grado.numero}° · Período ${periodo.numero}`}
          />

          {/* Crédito al autor */}
          <div class="text-center text-sm mt-10 mb-6" style="color: var(--fg-muted);">
            Autor: <strong style="color: var(--fg);">{proyecto.autor}</strong>
          </div>
        </>
      )}

      <!-- Volver -->
      <a
        href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}`}
        class="bento-card-hover flex items-center gap-4"
      >
        <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"></path>
          <path d="m12 19-7-7 7-7"></path>
        </svg>
        <div>
          <div class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">Volver al</div>
          <div class="font-black text-lg">Período {periodo.numero}</div>
        </div>
      </a>
    </div>
  </article>
</BaseLayout>

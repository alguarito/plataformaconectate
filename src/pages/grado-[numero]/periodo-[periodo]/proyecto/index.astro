---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CompletarBoton from '../../../../components/CompletarBoton.astro';
import CompartirWhatsApp from '../../../../components/CompartirWhatsApp.astro';
import { grados } from '../../../../data/grados';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const g of grados) {
    for (const p of g.periodos) {
      paths.push({
        params: { numero: String(g.numero), periodo: String(p.numero) },
        props: { grado: g, periodo: p },
      });
    }
  }
  return paths;
}

const { grado, periodo } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={`Proyecto Integrador · Grado ${grado.numero}° P${periodo.numero} — ConectaTE`}
  description={`Aplica todo lo aprendido en el período ${periodo.numero}: ${periodo.titulo}. Producto + presentación final.`}
  ogType="article"
>
  <article class="pt-12 pb-20">
    <div class="bento-container max-w-5xl">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm font-semibold mb-8 flex-wrap" style="color: var(--fg-muted);">
        <a href={base || '/'} class="hover:opacity-60 transition-opacity">Inicio</a>
        <span>/</span>
        <a href={`${base}/grado-${grado.numero}`} class="hover:opacity-60 transition-opacity">
          Grado {grado.numero}°
        </a>
        <span>/</span>
        <a href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}`} class="hover:opacity-60 transition-opacity">
          Período {periodo.numero}
        </a>
        <span>/</span>
        <span style="color: var(--fg);">Proyecto integrador</span>
      </nav>

      <!-- Hero card del proyecto -->
      <div class={`bento-card-color ${periodo.bgClass} mb-10 min-h-[360px] flex flex-col justify-between`}>
        <div class="flex items-start justify-between flex-wrap gap-3">
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              Grado {grado.numero}°
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              Período {periodo.numero}
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              🎯 Proyecto
            </span>
          </div>
          <span class="text-9xl">🎯</span>
        </div>

        <div>
          <span class="text-xs font-bold uppercase tracking-widest opacity-80">
            Proyecto Integrador · {periodo.titulo}
          </span>
          <h1 class="heading-giant text-balance mt-2">
            Aplica todo lo aprendido.
          </h1>
        </div>
      </div>

      <!-- Bento de información clave -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 mb-10">
        <!-- Duración -->
        <div class="bento-card-color bg-bento-cyan md:col-span-3 min-h-[180px] flex flex-col justify-between">
          <span class="text-xs font-bold uppercase tracking-widest opacity-80">Duración</span>
          <div>
            <div class="text-5xl font-black tracking-tighter leading-none">3-4</div>
            <div class="text-sm font-semibold mt-2">semanas</div>
          </div>
        </div>

        <!-- Modalidad -->
        <div class="bento-card-color bg-bento-yellow md:col-span-3 min-h-[180px] flex flex-col justify-between">
          <span class="text-xs font-bold uppercase tracking-widest opacity-80">Modalidad</span>
          <div>
            <div class="text-3xl font-black tracking-tight leading-tight">Individual<br/>o equipo</div>
          </div>
        </div>

        <!-- Entregable -->
        <div class="bento-card-color bg-bento-purple md:col-span-6 min-h-[180px] flex flex-col justify-between">
          <span class="text-xs font-bold uppercase tracking-widest opacity-80">Entregable</span>
          <div>
            <div class="text-2xl md:text-3xl font-black tracking-tight leading-tight">
              Producto + presentación final
            </div>
            <p class="text-sm opacity-80 mt-2">
              Demuestra tu aprendizaje creando algo real
            </p>
          </div>
        </div>
      </div>

      <CompletarBoton tipo="proyecto" grado={grado.numero} periodo={periodo.numero} />

      <CompartirWhatsApp
        titulo={`Proyecto Integrador · ${periodo.titulo}`}
        contexto={`Grado ${grado.numero}° · Período ${periodo.numero}`}
      />

      <!-- Fases del proyecto -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-6">Fases del proyecto</span>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-bento-sm bg-bento-blue text-white flex items-center justify-center text-xl font-black shrink-0">1</div>
            <div>
              <h3 class="text-lg font-black mb-1">Investigación</h3>
              <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
                Comprende el problema, investiga referentes, define alcance.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-bento-sm bg-bento-orange text-white flex items-center justify-center text-xl font-black shrink-0">2</div>
            <div>
              <h3 class="text-lg font-black mb-1">Diseño</h3>
              <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
                Bocetos, prototipos y plan de trabajo.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-bento-sm bg-bento-lime text-black flex items-center justify-center text-xl font-black shrink-0">3</div>
            <div>
              <h3 class="text-lg font-black mb-1">Construcción</h3>
              <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
                Desarrolla el producto integrando lo aprendido en las 10 sesiones.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-bento-sm bg-bento-pink text-white flex items-center justify-center text-xl font-black shrink-0">4</div>
            <div>
              <h3 class="text-lg font-black mb-1">Presentación</h3>
              <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
                Sustenta tu proyecto ante el grupo y recibe retroalimentación.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Criterios de evaluación (placeholder) -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-4">Criterios de evaluación</span>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
          <div>
            <div class="text-3xl font-black mb-1">30%</div>
            <h4 class="font-bold mb-1">Investigación</h4>
            <p class="text-xs" style="color: var(--fg-muted);">Calidad y profundidad del análisis previo</p>
          </div>
          <div>
            <div class="text-3xl font-black mb-1">40%</div>
            <h4 class="font-bold mb-1">Producto</h4>
            <p class="text-xs" style="color: var(--fg-muted);">Funcionalidad, estética y aplicación de conceptos</p>
          </div>
          <div>
            <div class="text-3xl font-black mb-1">30%</div>
            <h4 class="font-bold mb-1">Presentación</h4>
            <p class="text-xs" style="color: var(--fg-muted);">Claridad, dominio del tema y manejo de público</p>
          </div>
        </div>
      </div>

      <!-- Aviso -->
      <div class="bento-card-color bg-bento-yellow mb-10 flex items-start gap-4">
        <div class="text-5xl">📋</div>
        <div>
          <h3 class="text-xl font-black tracking-tight mb-1">Detalles específicos en preparación</h3>
          <p class="opacity-80 leading-relaxed">
            La consigna concreta del proyecto, los recursos, ejemplos y rúbrica
            detallada se publicarán pronto. Esta plantilla refleja la estructura
            general que tendrá cada proyecto integrador.
          </p>
        </div>
      </div>

      <!-- Volver -->
      <a
        href={`${base}/grado-${grado.numero}/periodo-${periodo.numero}`}
        class="bento-card-hover flex items-center gap-4"
      >
        <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"></path>
          <path d="m12 19-7-7 7-7"></path>
        </svg>
        <div>
          <div class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">Volver al</div>
          <div class="font-black text-lg">Período {periodo.numero}</div>
        </div>
      </a>
    </div>
  </article>
</BaseLayout>

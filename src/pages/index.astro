---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import GradoCard from '../components/GradoCard.astro';
import { grados } from '../data/grados';

const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <Hero />

  <!-- Bento Grid Asimétrico de Grados -->
  <section id="grados" class="pb-20">
    <div class="bento-container">
      <div class="flex items-end justify-between mb-10 flex-wrap gap-4">
        <div>
          <span class="chip-bento mb-4">Por grados</span>
          <h2 class="heading-huge text-balance max-w-2xl">
            Elige tu grado y empieza a aprender.
          </h2>
        </div>
      </div>

      <!-- Grid Bento asimétrico real -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 auto-rows-min">
        <!-- Grado 6 - LARGE (8 cols, 2 rows) -->
        <GradoCard
          numero={grados[0].numero}
          titulo={grados[0].titulo}
          descripcion={grados[0].descripcion}
          bgClass={grados[0].bgClass}
          icono={grados[0].icono}
          href={`${base}/grado-${grados[0].numero}`}
          size="large"
        />
        <!-- Grado 7 - normal -->
        <GradoCard
          numero={grados[1].numero}
          titulo={grados[1].titulo}
          descripcion={grados[1].descripcion}
          bgClass={grados[1].bgClass}
          icono={grados[1].icono}
          href={`${base}/grado-${grados[1].numero}`}
        />
        <!-- Grado 8 - normal -->
        <GradoCard
          numero={grados[2].numero}
          titulo={grados[2].titulo}
          descripcion={grados[2].descripcion}
          bgClass={grados[2].bgClass}
          icono={grados[2].icono}
          href={`${base}/grado-${grados[2].numero}`}
        />
        <!-- Grado 9 - normal -->
        <GradoCard
          numero={grados[3].numero}
          titulo={grados[3].titulo}
          descripcion={grados[3].descripcion}
          bgClass={grados[3].bgClass}
          icono={grados[3].icono}
          href={`${base}/grado-${grados[3].numero}`}
        />
        <!-- Grado 10 - normal -->
        <GradoCard
          numero={grados[4].numero}
          titulo={grados[4].titulo}
          descripcion={grados[4].descripcion}
          bgClass={grados[4].bgClass}
          icono={grados[4].icono}
          href={`${base}/grado-${grados[4].numero}`}
        />
        <!-- Grado 11 - normal -->
        <GradoCard
          numero={grados[5].numero}
          titulo={grados[5].titulo}
          descripcion={grados[5].descripcion}
          bgClass={grados[5].bgClass}
          icono={grados[5].icono}
          href={`${base}/grado-${grados[5].numero}`}
        />
      </div>
    </div>
  </section>

  <!-- Sección de Características - Bento -->
  <section class="pb-20">
    <div class="bento-container">
      <div class="mb-10">
        <span class="chip-bento mb-4">¿Qué ofrece?</span>
        <h2 class="heading-huge text-balance max-w-2xl">
          Todo lo que necesitas para aprender.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
        <!-- 180 Guías - Card grande negra -->
        <div class="bento-card-color bg-bento-black md:col-span-6 min-h-[300px] flex flex-col justify-between">
          <div class="text-9xl font-black tracking-tighter leading-none">180</div>
          <div>
            <h3 class="text-3xl md:text-4xl font-black tracking-tight mb-2">Guías de aprendizaje</h3>
            <p class="opacity-70">10 guías × 3 períodos × 6 grados</p>
          </div>
        </div>

        <!-- 18 Proyectos - Lima -->
        <div class="bento-card-color bg-bento-lime md:col-span-3 min-h-[300px] flex flex-col justify-between">
          <div class="text-8xl font-black tracking-tighter leading-none">18</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Proyectos integradores</h3>
            <p class="opacity-80 text-sm">Uno por período</p>
          </div>
        </div>

        <!-- IA Tutor - Cyan -->
        <div class="bento-card-color bg-bento-cyan md:col-span-3 min-h-[300px] flex flex-col justify-between">
          <div class="text-7xl">🤖</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Tutor IA</h3>
            <p class="opacity-80 text-sm">Resuelve dudas 24/7</p>
          </div>
        </div>

        <!-- Simulaciones - Naranja -->
        <div class="bento-card-color bg-bento-orange md:col-span-4 min-h-[240px] flex flex-col justify-between">
          <div class="text-6xl">🧪</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Simulaciones</h3>
            <p class="opacity-80 text-sm">GeoGebra, Scratch, Tinkercad</p>
          </div>
        </div>

        <!-- Progreso - Pink -->
        <div class="bento-card-color bg-bento-pink md:col-span-4 min-h-[240px] flex flex-col justify-between">
          <div class="text-6xl">📊</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Sigue tu progreso</h3>
            <p class="opacity-80 text-sm">Regístrate y guarda avances</p>
          </div>
        </div>

        <!-- Responsive - Yellow -->
        <div class="bento-card-color bg-bento-yellow md:col-span-4 min-h-[240px] flex flex-col justify-between">
          <div class="text-6xl">📱</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Cualquier dispositivo</h3>
            <p class="opacity-80 text-sm">Móvil, tablet o computador</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="pb-24">
    <div class="bento-container">
      <div class="bento-card-color bg-bento-black text-center py-20 px-6 grid-pattern">
        <h2 class="heading-giant text-balance mb-6">
          ¿Listo para empezar?
        </h2>
        <p class="text-lg md:text-xl opacity-70 max-w-xl mx-auto mb-10 text-balance">
          Regístrate gratis y guarda tu progreso. O explora todo el contenido sin cuenta.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href={`${base}/registro`} class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full font-semibold text-sm bg-bento-lime text-black hover:scale-105 transition-transform">
            Crear mi cuenta
          </a>
          <a href="#grados" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full font-semibold text-sm border-2 border-white/30 text-white hover:border-white transition-colors">
            Explorar sin cuenta
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

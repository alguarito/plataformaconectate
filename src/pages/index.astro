---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import GradoCard from '../components/GradoCard.astro';
import { grados } from '../data/grados';

const base = import.meta.env.BASE_URL;
---

<BaseLayout>
  <Hero />

  <!-- Bento Grid Asimétrico de Grados -->
  <section id="grados" class="pb-20">
    <div class="bento-container">
      <div class="flex items-end justify-between mb-10 flex-wrap gap-4">
        <div>
          <span class="chip-bento mb-4">Por grados</span>
          <h2 class="heading-huge text-balance max-w-2xl">
            Elige tu grado y empieza a aprender.
          </h2>
        </div>
      </div>

      {/* Chip de filtro activo (solo móvil, oculto por defecto) */}
      <div
        id="grado-filter-chip"
        class="hidden mb-6 md:hidden"
      >
        <button
          type="button"
          data-clear-grado-filter
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full font-bold text-sm bg-bento-blue text-white hover:opacity-90 transition-opacity"
        >
          <span>Filtro: Grado <span data-filter-grado-num>—</span>°</span>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Grid Bento asimétrico real -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 auto-rows-min">
        <!-- Grado 6 - LARGE (8 cols, 2 rows) -->
        <GradoCard
          numero={grados[0].numero}
          titulo={grados[0].titulo}
          descripcion={grados[0].descripcion}
          bgClass={grados[0].bgClass}
          icono={grados[0].icono}
          href={`${base}/grado-${grados[0].numero}`}
          size="large"
        />
        <!-- Grado 7 - normal -->
        <GradoCard
          numero={grados[1].numero}
          titulo={grados[1].titulo}
          descripcion={grados[1].descripcion}
          bgClass={grados[1].bgClass}
          icono={grados[1].icono}
          href={`${base}/grado-${grados[1].numero}`}
        />
        <!-- Grado 8 - normal -->
        <GradoCard
          numero={grados[2].numero}
          titulo={grados[2].titulo}
          descripcion={grados[2].descripcion}
          bgClass={grados[2].bgClass}
          icono={grados[2].icono}
          href={`${base}/grado-${grados[2].numero}`}
        />
        <!-- Grado 9 - normal -->
        <GradoCard
          numero={grados[3].numero}
          titulo={grados[3].titulo}
          descripcion={grados[3].descripcion}
          bgClass={grados[3].bgClass}
          icono={grados[3].icono}
          href={`${base}/grado-${grados[3].numero}`}
        />
        <!-- Grado 10 - normal -->
        <GradoCard
          numero={grados[4].numero}
          titulo={grados[4].titulo}
          descripcion={grados[4].descripcion}
          bgClass={grados[4].bgClass}
          icono={grados[4].icono}
          href={`${base}/grado-${grados[4].numero}`}
        />
        <!-- Grado 11 - normal -->
        <GradoCard
          numero={grados[5].numero}
          titulo={grados[5].titulo}
          descripcion={grados[5].descripcion}
          bgClass={grados[5].bgClass}
          icono={grados[5].icono}
          href={`${base}/grado-${grados[5].numero}`}
        />
      </div>
    </div>
  </section>

  <!-- Sección de Características - Bento -->
  <section class="pb-20">
    <div class="bento-container">
      <div class="mb-10">
        <span class="chip-bento mb-4">¿Qué ofrece?</span>
        <h2 class="heading-huge text-balance max-w-2xl">
          Todo lo que necesitas para aprender.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
        <!-- 180 Guías - Card grande negra -->
        <div class="bento-card-color bg-bento-black md:col-span-6 min-h-[300px] flex flex-col justify-between">
          <div class="text-9xl font-black tracking-tighter leading-none">180</div>
          <div>
            <h3 class="text-3xl md:text-4xl font-black tracking-tight mb-2">Guías de aprendizaje</h3>
            <p class="opacity-70">10 guías × 3 períodos × 6 grados</p>
          </div>
        </div>

        <!-- 18 Proyectos - Lima -->
        <div class="bento-card-color bg-bento-lime md:col-span-3 min-h-[300px] flex flex-col justify-between">
          <div class="text-8xl font-black tracking-tighter leading-none">18</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Proyectos integradores</h3>
            <p class="opacity-80 text-sm">Uno por período</p>
          </div>
        </div>

        <!-- IA Tutor - Cyan -->
        <div class="bento-card-color bg-bento-cyan md:col-span-3 min-h-[300px] flex flex-col justify-between">
          <div class="text-7xl">🤖</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Tutor IA</h3>
            <p class="opacity-80 text-sm">Resuelve dudas 24/7</p>
          </div>
        </div>

        <!-- Simulaciones - Naranja -->
        <div class="bento-card-color bg-bento-orange md:col-span-4 min-h-[240px] flex flex-col justify-between">
          <div class="text-6xl">🧪</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Simulaciones</h3>
            <p class="opacity-80 text-sm">GeoGebra, Scratch, Tinkercad</p>
          </div>
        </div>

        <!-- Progreso - Pink -->
        <div class="bento-card-color bg-bento-pink md:col-span-4 min-h-[240px] flex flex-col justify-between">
          <div class="text-6xl">📊</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Sigue tu progreso</h3>
            <p class="opacity-80 text-sm">Regístrate y guarda avances</p>
          </div>
        </div>

        <!-- Responsive - Yellow -->
        <div class="bento-card-color bg-bento-yellow md:col-span-4 min-h-[240px] flex flex-col justify-between">
          <div class="text-6xl">📱</div>
          <div>
            <h3 class="text-2xl font-black tracking-tight mb-1">Cualquier dispositivo</h3>
            <p class="opacity-80 text-sm">Móvil, tablet o computador</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Bottom sheet selector de grado (solo móvil) */}
  <dialog
    id="grado-picker-dialog"
    class="md:hidden bg-transparent p-0 m-0 max-w-none w-full max-h-none h-full backdrop:bg-black/60"
  >
    <div class="fixed inset-x-0 bottom-0 max-h-[85vh] overflow-y-auto rounded-t-3xl shadow-2xl" style="background: var(--bg);">
      <div class="p-6">
        {/* Drag handle visual */}
        <div class="w-12 h-1.5 rounded-full mx-auto mb-6" style="background: var(--border);"></div>

        <div class="flex items-start justify-between mb-6">
          <div>
            <span class="chip-bento mb-2">Selecciona</span>
            <h2 class="text-2xl font-black tracking-tight">Tu grado</h2>
          </div>
          <button
            type="button"
            data-close-grado-picker
            aria-label="Cerrar"
            class="w-10 h-10 rounded-full flex items-center justify-center hover:opacity-70 transition-opacity"
            style="background: var(--border);"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>

        <div class="grid grid-cols-2 gap-3 mb-3">
          {grados.map((g) => (
            <button
              type="button"
              data-pick-grado={g.numero}
              class={`bento-card-color ${g.bgClass} text-left p-5 active:scale-95 transition-transform`}
            >
              <div class="text-4xl font-black tracking-tighter leading-none mb-2">
                {g.numero}°
              </div>
              <div class="text-xs font-bold opacity-80 line-clamp-2 leading-tight">
                {g.titulo}
              </div>
            </button>
          ))}
        </div>

        <button
          type="button"
          data-pick-grado="all"
          class="w-full mt-3 py-4 rounded-bento-sm font-bold text-sm border-2 hover:opacity-70 transition-opacity"
          style="border-color: var(--border); color: var(--fg);"
        >
          Ver todos los grados
        </button>
      </div>
    </div>
  </dialog>

  <!-- CTA Final -->
  <section class="pb-24">
    <div class="bento-container">
      <div class="bento-card-color bg-bento-black text-center py-20 px-6 grid-pattern">
        <h2 class="heading-giant text-balance mb-6">
          ¿Listo para empezar?
        </h2>
        <p class="text-lg md:text-xl opacity-70 max-w-xl mx-auto mb-10 text-balance">
          Regístrate gratis y guarda tu progreso. O explora todo el contenido sin cuenta.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href={`${base}/registro`} class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full font-semibold text-sm bg-bento-lime text-black hover:scale-105 transition-transform">
            Crear mi cuenta
          </a>
          <a href="#grados" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full font-semibold text-sm border-2 border-white/30 text-white hover:border-white transition-colors">
            Explorar sin cuenta
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Selector de grado en móvil — filtra la home a un grado o vuelve a "todos"
    const dialog = document.getElementById('grado-picker-dialog') as HTMLDialogElement | null;
    const chip = document.getElementById('grado-filter-chip');
    const chipNum = document.querySelector<HTMLElement>('[data-filter-grado-num]');
    const cards = document.querySelectorAll<HTMLElement>('[data-grado-card]');

    function applyFilter(grado: string | null) {
      if (!grado || grado === 'all') {
        // Mostrar todas
        cards.forEach((c) => c.removeAttribute('data-grado-hidden'));
        chip?.classList.add('hidden');
      } else {
        cards.forEach((c) => {
          if (c.dataset.gradoCard === grado) {
            c.removeAttribute('data-grado-hidden');
          } else {
            c.setAttribute('data-grado-hidden', '');
          }
        });
        if (chip && chipNum) {
          chipNum.textContent = grado;
          chip.classList.remove('hidden');
        }
      }
    }

    // Abrir dialog
    document.querySelectorAll('[data-open-grado-picker]').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (typeof dialog?.showModal === 'function') {
          dialog.showModal();
        }
      });
    });

    // Cerrar dialog (botón X)
    document.querySelectorAll('[data-close-grado-picker]').forEach((btn) => {
      btn.addEventListener('click', () => dialog?.close());
    });

    // Cerrar al tocar fuera del contenido (en el backdrop)
    dialog?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === dialog) dialog.close();
    });

    // Seleccionar grado
    document.querySelectorAll<HTMLButtonElement>('[data-pick-grado]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const grado = btn.dataset.pickGrado || null;
        applyFilter(grado);
        dialog?.close();
        // Scroll suave a la sección de grados
        document.getElementById('grados')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // Limpiar filtro desde el chip
    document.querySelectorAll('[data-clear-grado-filter]').forEach((btn) => {
      btn.addEventListener('click', () => applyFilter('all'));
    });
  </script>

  <style is:global>
    /* Oculta tarjetas de grado filtradas (solo aplica si tienen el atributo) */
    [data-grado-card][data-grado-hidden] {
      display: none !important;
    }

    /* Animación suave del bottom sheet al abrir */
    #grado-picker-dialog[open] > div {
      animation: slide-up 0.25s ease-out;
    }
    @keyframes slide-up {
      from { transform: translateY(100%); }
      to { transform: translateY(0); }
    }
  </style>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { grados } from '../../data/grados';
import {
  planArea,
  fasesMILC,
  referentes,
  estrategias,
  componentesMEN,
  objetivos,
  criteriosEvaluacion,
  ponderacion,
} from '../../data/planArea';

const base = import.meta.env.BASE_URL;
const pdfHref = `${base}/plan-de-area/${planArea.pdf}`;
---

<BaseLayout
  title={`Plan de Área 2025 · ${planArea.area} — ConectaTE`}
  description={`${planArea.area} ${planArea.ano} · ${planArea.cobertura}. Modelo MILC: Escuta, Sistematización, Praxis y Evaluación liberadora. ${planArea.recursos.guias} guías + ${planArea.recursos.proyectos} proyectos integradores + ${planArea.recursos.examenes} exámenes.`}
  ogType="article"
>
  <article class="pt-12 pb-20">
    <div class="bento-container max-w-6xl">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm font-semibold mb-8 flex-wrap" style="color: var(--fg-muted);">
        <a href={base || '/'} class="hover:opacity-60 transition-opacity">Inicio</a>
        <span>/</span>
        <span style="color: var(--fg);">Plan de Área 2025</span>
      </nav>

      <!-- HERO -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 mb-10">
        <div class="bento-card-color bg-bento-blue md:col-span-8 min-h-[420px] flex flex-col justify-between">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              📚 Documento rector · {planArea.ano}
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              {planArea.cobertura}
            </span>
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest bg-black/15">
              MILC · Liberador
            </span>
          </div>

          <div>
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">Plan de Área {planArea.ano}</span>
            <h1 class="heading-giant text-balance leading-[0.95] mt-1 mb-3">
              {planArea.area}.
            </h1>
            <p class="text-base md:text-lg font-semibold opacity-90 leading-snug max-w-xl">
              {planArea.institucion} · {planArea.ciudad}
            </p>
            <p class="text-sm opacity-80 mt-2">
              Autor: <strong>{planArea.autor}</strong>
            </p>
          </div>
        </div>

        <!-- Tarjeta lateral: descarga del PDF -->
        <a
          href={pdfHref}
          download
          class="bento-card-color bg-bento-purple md:col-span-4 flex flex-col justify-between min-h-[420px] hover:scale-[1.01] transition-transform group"
        >
          <div>
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">PDF · 165 KB</span>
            <div class="text-7xl mt-3">📄</div>
          </div>
          <div>
            <h3 class="text-2xl md:text-3xl font-black tracking-tight leading-tight mb-2">
              Documento completo
            </h3>
            <p class="text-sm opacity-80 mb-3 leading-relaxed">
              {planArea.paginas} páginas con mallas curriculares por grado, marco teórico y rúbricas
            </p>
            <div class="inline-flex items-center gap-2 font-bold text-sm group-hover:gap-3 transition-all">
              Descargar
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
            </div>
          </div>
        </a>
      </div>

      <!-- IDEA FUERZA -->
      <div class="bento-card-color bg-bento-yellow mb-10 py-12 px-6 md:py-16 md:px-10 text-center">
        <span class="chip-bento mb-4 bg-black/10 border-black/20" style="color: rgba(0,0,0,0.7);">Idea fuerza</span>
        <p class="text-2xl md:text-3xl font-black tracking-tight leading-tight max-w-3xl mx-auto">
          "{planArea.ideaFuerza}"
        </p>
      </div>

      <!-- MODELO MILC -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-3">Modelo MILC</span>
        <h2 class="heading-huge mb-2 leading-tight">
          Investigación · Liberación · Ciencia.
        </h2>
        <p class="text-sm md:text-base mb-8 leading-relaxed" style="color: var(--fg-muted);">
          El Modelo MILC convierte cada clase en un proceso de investigación escolar.
          El estudiante escucha el contexto, organiza lo que encuentra, actúa mediante
          productos o prototipos y evalúa críticamente el sentido de lo realizado.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
          {fasesMILC.map((f, i) => (
            <div class={`bento-card-color ${f.bgClass} flex gap-4 items-start min-h-[180px]`}>
              <div class="text-5xl shrink-0">{f.emoji}</div>
              <div>
                <span class="text-xs font-bold uppercase tracking-widest opacity-80">
                  Fase {i + 1}
                </span>
                <h3 class="text-xl md:text-2xl font-black tracking-tight leading-tight mt-1 mb-2">
                  {f.nombre}
                </h3>
                <p class="text-sm leading-relaxed opacity-90">
                  {f.descripcion}
                </p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 p-4 rounded-bento-sm" style="background: var(--bg);">
          <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
            <strong style="color: var(--fg);">Principio de diseño:</strong> toda guía
            debe tener pregunta, contexto, producción, reflexión y evidencia; todo
            proyecto debe pasar por escucha, análisis, creación y evaluación social.
          </p>
        </div>
      </div>

      <!-- META DE EGRESO -->
      <div class="bento-card-color bg-bento-lime mb-10 flex items-start gap-4">
        <div class="text-5xl shrink-0">🎯</div>
        <div>
          <span class="text-xs font-bold uppercase tracking-widest opacity-80">Meta de egreso</span>
          <h3 class="text-xl md:text-2xl font-black tracking-tight leading-tight mt-2">
            {planArea.metaEgreso}
          </h3>
        </div>
      </div>

      <!-- OBJETIVOS FORMATIVOS -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-3">Objetivos formativos del área</span>
        <h2 class="heading-huge mb-2 leading-tight">5 metas que guían el currículo.</h2>

        <ul class="space-y-4 mt-8">
          {objetivos.map((o, i) => (
            <li class="flex items-start gap-4">
              <span class="w-9 h-9 rounded-bento-sm bg-bento-blue text-white flex items-center justify-center text-sm font-black shrink-0">
                {i + 1}
              </span>
              <span class="text-base md:text-lg leading-relaxed">{o}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- COMPONENTES MEN -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-3">Componentes MEN · Guía No. 30</span>
        <h2 class="heading-huge mb-2 leading-tight">4 ejes de lectura curricular.</h2>
        <p class="text-sm md:text-base mb-8 leading-relaxed" style="color: var(--fg-muted);">
          Articulación con el marco oficial del Ministerio de Educación Nacional para
          la educación en tecnología.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {componentesMEN.map((c) => (
            <div class="flex items-start gap-3 p-4 rounded-bento-sm" style="background: var(--bg);">
              <div class="text-3xl shrink-0">{c.emoji}</div>
              <div>
                <h3 class="font-black leading-tight mb-1">{c.nombre}</h3>
                <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
                  {c.descripcion}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ESTRATEGIAS ACTIVAS -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-3">Estrategias activas de aprendizaje</span>
        <h2 class="heading-huge mb-2 leading-tight">6 metodologías que vertebran el aula.</h2>
        <p class="text-sm md:text-base mb-8 leading-relaxed" style="color: var(--fg-muted);">
          Combinadas con MILC, hacen que cada clase sea experiencia de producción
          y pensamiento, no de repetición técnica.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {estrategias.map((e) => (
            <div class="p-4 rounded-bento-sm border-2" style="border-color: var(--border);">
              <div class="text-3xl mb-2">{e.emoji}</div>
              <h3 class="font-black leading-tight mb-1">{e.nombre}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
                {e.descripcion}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- EVALUACIÓN LIBERADORA -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 mb-10">
        <!-- Criterios -->
        <div class="bento-card md:col-span-7">
          <span class="chip-bento mb-3">Evaluación liberadora</span>
          <h2 class="heading-huge mb-2 leading-tight">4 criterios integrales.</h2>
          <p class="text-sm md:text-base mb-6 leading-relaxed" style="color: var(--fg-muted);">
            Formativa, criterial, integral y liberadora — coherente con el SIEE
            institucional.
          </p>

          <div class="space-y-4 mt-6">
            {criteriosEvaluacion.map((c) => (
              <div class="flex items-start gap-3">
                <div class="text-3xl shrink-0">{c.emoji}</div>
                <div>
                  <h3 class="font-black leading-tight mb-1">{c.nombre}</h3>
                  <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
                    {c.descripcion}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Ponderación -->
        <div class="bento-card-color bg-bento-orange md:col-span-5 flex flex-col justify-between min-h-[420px]">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">
              Ponderación orientativa por período
            </span>
            <h3 class="text-3xl font-black tracking-tight mt-2 leading-tight">
              100% del período
            </h3>
            <p class="text-sm opacity-80 mt-2 leading-relaxed">
              Distribución sugerida — ajustable al SIEE institucional.
            </p>
          </div>

          <ul class="space-y-3 mt-6">
            {ponderacion.map((p) => (
              <li>
                <div class="flex items-baseline justify-between mb-1">
                  <span class="font-bold text-sm md:text-base">{p.item}</span>
                  <span class="text-2xl font-black tracking-tight">{p.porcentaje}%</span>
                </div>
                <div class="w-full h-2 rounded-full bg-black/20 overflow-hidden">
                  <div
                    class="h-full bg-white rounded-full"
                    style={`width: ${p.porcentaje * 3}%`}
                  ></div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- MARCO TEÓRICO / REFERENTES -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-3">Marco teórico</span>
        <h2 class="heading-huge mb-2 leading-tight">7 referentes que sostienen el plan.</h2>
        <p class="text-sm md:text-base mb-8 leading-relaxed" style="color: var(--fg-muted);">
          MILC no inventa de cero: integra a los grandes referentes pedagógicos,
          filosóficos y tecnológicos en un lenguaje pedagógico operativo para el aula.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
          {referentes.map((r) => (
            <div class="p-5 rounded-bento-sm border-2" style="border-color: var(--border);">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-3xl">{r.emoji}</span>
                <div>
                  <h3 class="font-black leading-tight">{r.autor}</h3>
                  <p class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">
                    {r.obra}
                  </p>
                </div>
              </div>
              <p class="text-sm leading-relaxed" style="color: var(--fg-muted);">
                {r.aporte}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- RECURSOS CURRICULARES -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-3">Recursos curriculares 2025</span>
        <h2 class="heading-huge mb-2 leading-tight">El plan vivo, en 216 piezas.</h2>
        <p class="text-sm md:text-base mb-8 leading-relaxed" style="color: var(--fg-muted);">
          Plan, guía, proyecto y examen forman partes de una misma arquitectura
          pedagógica con identidad visual y editorial común.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
          <div class="bento-card-color bg-bento-blue flex flex-col justify-between min-h-[180px]">
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">Guías</span>
            <div>
              <div class="text-7xl font-black tracking-tighter leading-none">{planArea.recursos.guias}</div>
              <div class="text-sm font-bold mt-2">de aprendizaje · 30 por grado</div>
            </div>
          </div>
          <div class="bento-card-color bg-bento-pink flex flex-col justify-between min-h-[180px]">
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">Proyectos</span>
            <div>
              <div class="text-7xl font-black tracking-tighter leading-none">{planArea.recursos.proyectos}</div>
              <div class="text-sm font-bold mt-2">integradores · 1 por período</div>
            </div>
          </div>
          <div class="bento-card-color bg-bento-cyan flex flex-col justify-between min-h-[180px]">
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">Exámenes</span>
            <div>
              <div class="text-7xl font-black tracking-tighter leading-none">{planArea.recursos.examenes}</div>
              <div class="text-sm font-bold mt-2">de síntesis · 1 por período</div>
            </div>
          </div>
        </div>
      </div>

      <!-- MALLAS POR GRADO (atajo a las páginas existentes) -->
      <div class="bento-card mb-10">
        <span class="chip-bento mb-3">Mallas curriculares por grado</span>
        <h2 class="heading-huge mb-2 leading-tight">Entra a cada grado.</h2>
        <p class="text-sm md:text-base mb-8 leading-relaxed" style="color: var(--fg-muted);">
          Cada grado tiene su trayectoria de 30 guías + 3 proyectos integradores
          distribuidas en 3 períodos académicos.
        </p>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 md:gap-4">
          {grados.map((g) => (
            <a
              href={`${base}/grado-${g.numero}`}
              class={`bento-card-color ${g.bgClass} flex flex-col items-start gap-3 aspect-square hover:scale-[1.02] active:scale-[0.99] transition-transform`}
            >
              <span class="text-xs font-bold uppercase tracking-widest opacity-80">
                Grado
              </span>
              <span class="text-5xl md:text-6xl font-black tracking-tighter leading-none mt-auto">
                {g.numero}°
              </span>
            </a>
          ))}
        </div>
      </div>

      <!-- CTA — Descarga del PDF completo -->
      <div class="bento-card-color bg-bento-black grid-pattern py-12 md:py-16 px-6 md:px-10 mb-10">
        <div class="text-center max-w-2xl mx-auto">
          <span class="chip-bento mb-3 bg-white/10 text-white">Documento oficial</span>
          <h2 class="heading-huge mb-3 leading-tight">¿Necesitas todo el documento?</h2>
          <p class="text-base md:text-lg opacity-80 mb-8 leading-relaxed">
            La versión PDF de {planArea.paginas} páginas incluye marco teórico
            ampliado, mallas detalladas por grado, anexo de correspondencia de
            recursos y referencias bibliográficas completas.
          </p>

          <a
            href={pdfHref}
            download
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full font-bold text-sm bg-bento-lime text-black hover:scale-105 transition-transform"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Descargar Plan de Área 2025 (PDF · 165 KB)
          </a>

          <p class="text-xs opacity-60 mt-4">
            Versión editorial MILC · {planArea.institucion}
          </p>
        </div>
      </div>

      <!-- VOLVER -->
      <a
        href={base || '/'}
        class="bento-card-hover flex items-center gap-4"
      >
        <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"></path>
          <path d="m12 19-7-7 7-7"></path>
        </svg>
        <div>
          <div class="text-xs font-bold uppercase tracking-widest" style="color: var(--fg-muted);">Volver al</div>
          <div class="font-black text-lg">Inicio de ConectaTE</div>
        </div>
      </a>
    </div>
  </article>
</BaseLayout>
